<div class="terms-page">
  <div class="terms-shell">
    <aside class="terms-toc" aria-label="Contents">
      <div class="terms-toc__inner">
        <div class="terms-toc__title">Contents</div>

        <button class="terms-toc__toggle" type="button" aria-expanded="false" aria-controls="termsTocList">
          Jump to section
        </button>

        <nav id="termsTocList" class="terms-toc__list" aria-label="Terms contents">
          <!-- Auto-filled by JS -->
        </nav>
      </div>
    </aside>

    <main class="terms-content" id="termsContent">
      {{ page.content }}
    </main>
  </div>
</div>
>