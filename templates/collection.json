        "custom_liquid": "{% if collection.metafields.custom.collection_description_top_html.value != blank %}\n<div class=\"collection-top-section\">\n  <div class=\"rich-text--container\">\n    <div class=\"collection-intro-wrap\">\n      {{ collection.metafields.custom.collection_description_top_html.value }}\n    </div>\n    <button type=\"button\" class=\"collection-intro-toggle\" aria-expanded=\"false\">Read more &#8595;</button>\n  </div>\n</div>\n\n<style>\n.collection-top-section {\n  background: var(--wll-bg, #f5f5f7);\n  width: 100vw; position: relative; left: 50%; right: 50%;\n  margin-left: -50vw; margin-right: -50vw;\n  padding: 2.5rem 1.5rem;\n  font-family: var(--wll-font, 'Inter', sans-serif);\n}\n.collection-top-section .rich-text--container {\n  max-width: 1200px; margin: 0 auto; padding: 0;\n  font-size: 1rem; line-height: 1.55;\n  color: var(--wll-text, #1B2034);\n}\n.collection-top-section .collection-intro-wrap > :first-child,\n.collection-top-section .collection-intro-wrap > div > :first-child {\n  font-size: 1.1875rem; font-weight: 600;\n  letter-spacing: var(--wll-tracking-snug, -0.018em);\n  margin-top: 0;\n}\n.collection-top-section a { color: var(--wll-accent-blue, #0076DE); text-underline-offset: 3px; }\n.collection-intro-more { display: none; }\n.collection-intro-more.is-open { display: block; margin-top: 0.875rem; }\n.collection-intro-toggle {\n  background: none; border: none; padding: 0; margin-top: 0.75rem;\n  color: var(--wll-navy, #1B2034); font-weight: 600; font-size: 0.95rem;\n  font-family: inherit; cursor: pointer; text-decoration: underline; text-underline-offset: 3px;\n}\n.collection-intro-toggle:hover { color: var(--wll-accent-magenta, #d946ef); }\n@media (max-width: 768px) {\n  .collection-top-section { padding: 2rem 1.25rem; }\n  .collection-top-section .rich-text--container { font-size: 0.95rem; }\n  .collection-top-section .collection-intro-wrap > :first-child,\n  .collection-top-section .collection-intro-wrap > div > :first-child { font-size: 1.05rem; }\n}\n</style>\n\n<script>\n(function() {\n  document.querySelectorAll('.collection-intro-wrap').forEach(function(wrap) {\n    var btn = wrap.nextElementSibling;\n    if (!btn || !btn.classList.contains('collection-intro-toggle')) return;\n    var container = wrap;\n    if (wrap.children.length === 1 && wrap.firstElementChild.tagName === 'DIV') {\n      container = wrap.firstElementChild;\n    }\n    var children = Array.from(container.children);\n    var firstParaIndex = -1;\n    for (var i = 0; i < children.length; i++) {\n      if (children[i].tagName === 'P') { firstParaIndex = i; break; }\n    }\n    if (firstParaIndex === -1 || firstParaIndex === children.length - 1) {\n      btn.style.display = 'none';\n      return;\n    }\n    var more = document.createElement('div');\n    more.className = 'collection-intro-more';\n    for (var j = firstParaIndex + 1; j < children.length; j++) {\n      more.appendChild(children[j]);\n    }\n    container.appendChild(more);\n    btn.addEventListener('click', function() {\n      var open = more.classList.toggle('is-open');\n      btn.setAttribute('aria-expanded', open);\n      btn.innerHTML = open ? 'Read less &#8593;' : 'Read more &#8595;';\n    });\n  });\n})();\n</script>\n{% endif %}"
