{%- comment -%}
  Lucide icon snippet — curated subset (12 icons) used by the Hub Q&A grid.

  Icons are inline SVGs from lucide.dev (MIT). stroke="currentColor" so the
  parent controls colour; class="lucide-icon" is a styling hook.

  @param icon {String} One of: lightbulb, wrench, cog, cable, plug, book,
                       help, clock, truck, shield, target, info.
                       Unknown / blank values fall back to 'help'.

  Usage: {%- render 'lucide-icon', icon: block.settings.icon -%}
{%- endcomment -%}

{%- liquid
  assign lucide_key = icon | default: 'help' | strip
  assign lucide_valid = 'lightbulb,wrench,cog,cable,plug,book,help,clock,truck,shield,target,info' | split: ','
  unless lucide_valid contains lucide_key
    assign lucide_key = 'help'
  endunless
-%}

<svg class="lucide-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
  {%- case lucide_key -%}
    {%- when 'lightbulb' -%}
      <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>
