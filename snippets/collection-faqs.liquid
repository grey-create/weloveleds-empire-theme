{% comment %} Collection FAQ Display - WeLoveLeds Brand Style {% endcomment %}
{% assign faq_sets = collection.metafields.custom.faq_sets.value %}

{% if faq_sets %}
  {% for faq_set in faq_sets %}
    {% assign faq_json = faq_set.faqs.value | default: faq_set.faqs %}
    {% assign parsed_faqs = faq_json | parse_json %}
    
    {% if parsed_faqs %}
      <div class="faq-section" style="max-width: 1200px; margin: 60px auto 40px; padding: 0 20px;">
        <h2 style="text-align: center; margin-bottom: 40px; font-size: 28px; font-weight: 400; color: #333; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
          Frequently Asked Questions
        </h2>
        
        <div class="faq-container" style="max-width: 900px; margin: 0 auto;">
          {% for faq in parsed_faqs %}
            <details class="faq-item" style="margin-bottom: 2px; border: none; background: white;">
              <summary style="cursor: pointer; padding: 20px 25px; background: #f8f8f8; border-left: 3px solid transparent; transition: all 0.3s ease; display: flex; justify-content: space-between; align-items: center; font-size: 16px; color: #333; list-style: none;">
                <span style="flex: 1; font-weight: 500;">{{ faq.question }}</span>
                <svg class="faq-arrow" style="width: 20px; height: 20px; transition: transform 0.3s ease; flex-shrink: 0; margin-left: 20px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div style="padding: 20px 25px 25px 28px; background: white; color: #666; line-height: 1.7; font-size: 15px; border-left: 3px solid #FDCD6A;">
                {{ faq.answer }}
              </div>
            </details>
          {% endfor %}
        </div>
      </div>

      <!-- FAQ Schema Markup -->
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {% for faq in parsed_faqs %}
          {
            "@type": "Question",
            "name": {{ faq.question | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ faq.answer | json }}
            }
          }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ]
      }
      </script>

      <style>
        .faq-item summary::-webkit-details-marker {
          display: none;
        }
        
        .faq-item summary:hover {
          background: #f0f0f0;
          border-left-color: #FDCD6A;
        }
        
        .faq-item[open] summary {
          background: white;
          border-left-color: #FDCD6A;
        }
        
        .faq-item[open] summary .faq-arrow {
          transform: rotate(180deg);
        }
        
        .faq-section {
          border-top: 1px solid #e5e5e5;
          padding-top: 60px !important;
        }
        
        @media (max-width: 768px) {
          .faq-section h2 {
            font-size: 24px;
            margin-bottom: 30px;
          }
          
          .faq-item summary {
            font-size: 15px;
            padding: 15px 20px;
          }
          
          .faq-item div {
            padding: 15px 20px 20px 23px;
            font-size: 14px;
          }
          
          .faq-arrow {
            width: 18px !important;
            height: 18px !important;
          }
        }
      </style>
    {% endif %}
  {% endfor %}
{% endif %}