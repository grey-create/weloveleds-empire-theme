{{ 'bento-carousel.css' | asset_url | stylesheet_tag }}

<div class="bento-carousel-section" style="background-color: {{ section.settings.background_colour }};">
  <div class="bento-carousel-container">
    
    {%- if section.settings.heading != blank -%}
      <p class="bento-carousel-heading">{{ section.settings.heading }}</p>
    {%- endif -%}

    <div class="bento-carousel" 
         data-autoplay="{{ section.settings.autoplay }}" 
         data-interval="{{ section.settings.interval }}"
         data-total-slides="{{ section.blocks.size }}">
      <div class="bento-carousel__viewport">
        <div class="bento-carousel__track">
          {%- for block in section.blocks -%}
            <div class="bento-carousel__slide" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.collection.url }}" class="bento-carousel__slide-link">
                <div class="bento-carousel__slide-inner" style="--slide-radius: {{ section.settings.border_radius }}px;">
                  <div class="bento-carousel__background">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'bento-carousel__image' }}
                    {%- endif -%}
                    {%- if block.settings.fade_to_transparent -%}
                      {%- assign fade_opacity = block.settings.fade_opacity | divided_by: 100.0 -%}
                      <div class="bento-carousel__overlay" style="background: linear-gradient(to top, {{ block.settings.fade_colour | color_modify: 'alpha', fade_opacity }} 0%, transparent 60%);"></div>
                    {%- else -%}
                      <div class="bento-carousel__overlay" style="background: {{ block.settings.overlay }};"></div>
                    {%- endif -%}
                  </div>
                  <div class="bento-carousel__content">
                    <h3 class="bento-carousel__title">
                      {%- if block.settings.custom_title != blank -%}
                        {{ block.settings.custom_title }}
                      {%- else -%}
                        {{ block.settings.collection.title }}
                      {%- endif -%}
                    </h3>
                    {%- if block.settings.tagline != blank -%}
                      <p class="bento-carousel__tagline">{{ block.settings.tagline }}</p>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            </div>
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} Navigation Dots {%- endcomment -%}
      <div class="bento-carousel__dots">
        {%- for block in section.blocks -%}
          <button class="bento-carousel__dot {% if forloop.first %}bento-carousel__dot--active{% endif %}" 
                  data-slide="{{ forloop.index0 }}" 
                  aria-label="Go to slide {{ forloop.index }}">
          </button>
        {%- endfor -%}
        
        {%- if section.settings.autoplay -%}
          <button class="bento-carousel__pause" aria-label="Pause slideshow">
            <svg class="bento-carousel__pause-icon" width="12" height="12" viewBox="0 0 12 12" fill="currentColor">
              <rect x="2" y="2" width="3" height="8" rx="0.5"/>
              <rect x="7" y="2" width="3" height="8" rx="0.5"/>
            </svg>
            <svg class="bento-carousel__play-icon" width="12" height="12" viewBox="0 0 12 12" fill="currentColor" style="display: none;">
              <path d="M3 2l7 4-7 4V2z"/>
            </svg>
          </button>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const carousels = document.querySelectorAll('.bento-carousel');
  
  carousels.forEach(carousel => {
    const track = carousel.querySelector('.bento-carousel__track');
    const slides = Array.from(carousel.querySelectorAll('.bento-carousel__slide'));
    const dots = carousel.querySelectorAll('.bento-carousel__dot');
    const pauseBtn = carousel.querySelector('.bento-carousel__pause');
    const autoplay = carousel.dataset.autoplay === 'true';
    const interval = parseInt(carousel.dataset.interval) || 5000;
    
    let currentIndex = 0;
    let autoplayTimer = null;
    let isPaused = false;
    const totalSlides = slides.length;

    // Clone slides for infinite loop
    function setupInfiniteLoop() {
      // Clone all slides and append to end
      slides.forEach(slide => {
        const clone = slide.cloneNode(true);
        clone.classList.add('bento-carousel__slide--clone');
        track.appendChild(clone);
      });
      // Clone all slides and prepend to start
      for (let i = slides.length - 1; i >= 0; i--) {
        const clone = slides[i].cloneNode(true);
        clone.classList.add('bento-carousel__slide--clone');
        track.insertBefore(clone, track.firstChild);
      }
    }

    function getSlideWidth() {
      const slide = track.querySelector('.bento-carousel__slide');
      const gap = parseFloat(getComputedStyle(track).gap) || 16;
      return slide.offsetWidth + gap;
    }

    function updatePosition(animate = true) {
      const slideWidth = getSlideWidth();
      // Offset by totalSlides because we prepended clones
      const offset = (currentIndex + totalSlides) * slideWidth;
      // Centre the active slide
      const viewportWidth = carousel.querySelector('.bento-carousel__viewport').offsetWidth;
      const centreOffset = (viewportWidth / 2) - (slides[0].offsetWidth / 2);
      
      if (!animate) {
        track.style.transition = 'none';
      } else {
        track.style.transition = 'transform 0.9s cubic-bezier(0.45, 0, 0.15, 1)';
      }
      
      track.style.transform = `translateX(${centreOffset - offset}px)`;

      // Update opacity based on distance from centre
      const allSlides = track.querySelectorAll('.bento-carousel__slide');
      allSlides.forEach((slide, index) => {
        // Calculate position relative to active (accounting for clones)
        const adjustedIndex = index - totalSlides; // Remove prepended clone offset
        const distanceFromActive = Math.abs(adjustedIndex - currentIndex);
        
        // Opacity: 1 for active, 0.5 for adjacent, 0.3 for further
        let opacity = 1;
        if (distanceFromActive === 1) opacity = 0.5;
        else if (distanceFromActive === 2) opacity = 0.35;
        else if (distanceFromActive > 2) opacity = 0.25;
        
        slide.style.opacity = opacity;
        
        // Update active class
        slide.classList.toggle('bento-carousel__slide--active', distanceFromActive === 0);
      });

      // Update dots
      dots.forEach((dot, index) => {
        dot.classList.toggle('bento-carousel__dot--active', index === currentIndex);
      });
    }

    function handleInfiniteLoop() {
      // Check if we need to jump to maintain infinite illusion
      if (currentIndex >= totalSlides) {
        currentIndex = 0;
        setTimeout(() => updatePosition(false), 50);
      } else if (currentIndex < 0) {
        currentIndex = totalSlides - 1;
        setTimeout(() => updatePosition(false), 50);
      }
    }

    function goToSlide(index, animate = true) {
      currentIndex = index;
      updatePosition(animate);
      
      // Handle infinite loop jump after animation
      if (animate) {
        setTimeout(handleInfiniteLoop, 950);
      }
    }

    function nextSlide() {
      currentIndex++;
      updatePosition(true);
      setTimeout(handleInfiniteLoop, 950);
    }

    function prevSlide() {
      currentIndex--;
      updatePosition(true);
      setTimeout(handleInfiniteLoop, 950);
    }

    function startAutoplay() {
      if (autoplay && !isPaused && totalSlides > 1) {
        stopAutoplay();
        autoplayTimer = setInterval(nextSlide, interval);
      }
    }

    function stopAutoplay() {
      if (autoplayTimer) {
        clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    }

    // Dot click handlers
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        stopAutoplay();
        goToSlide(index);
        startAutoplay();
      });
    });

    // Pause button
    if (pauseBtn) {
      const pauseIcon = pauseBtn.querySelector('.bento-carousel__pause-icon');
      const playIcon = pauseBtn.querySelector('.bento-carousel__play-icon');
      
      pauseBtn.addEventListener('click', () => {
        isPaused = !isPaused;
        if (isPaused) {
          stopAutoplay();
          pauseIcon.style.display = 'none';
          playIcon.style.display = 'block';
        } else {
          startAutoplay();
          pauseIcon.style.display = 'block';
          playIcon.style.display = 'none';
        }
      });
    }

    // Touch/swipe support
    let touchStartX = 0;

    carousel.addEventListener('touchstart', e => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    carousel.addEventListener('touchend', e => {
      const touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      
      if (Math.abs(diff) > 50) {
        stopAutoplay();
        if (diff > 0) {
          nextSlide();
        } else {
          prevSlide();
        }
        startAutoplay();
      }
    }, { passive: true });

    // Pause on hover
    carousel.addEventListener('mouseenter', stopAutoplay);
    carousel.addEventListener('mouseleave', () => {
      if (!isPaused) startAutoplay();
    });

    // Handle resize
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => updatePosition(false), 150);
    });

    // Initialize
    setupInfiniteLoop();
    updatePosition(false);
    startAutoplay();
  });
});
</script>

{% schema %}
{
  "name": "Bento Carousel",
  "tag": "section",
  "class": "bento-carousel-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "More to explore"
    },
    {
      "type": "color",
      "id": "background_colour",
      "label": "Background colour",
      "default": "#f5f5f7"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 1400,
      "max": 2400,
      "step": 100,
      "default": 1800,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Slide corner radius",
      "min": 0,
      "max": 32,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "interval",
      "label": "Slide interval",
      "min": 3000,
      "max": 8000,
      "step": 500,
      "default": 5000,
      "unit": "ms"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "color_background",
          "id": "overlay",
          "label": "Overlay gradient",
          "default": "linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 50%)"
        },
        {
          "type": "checkbox",
          "id": "fade_to_transparent",
          "label": "Use simple bottom fade",
          "default": true
        },
        {
          "type": "color",
          "id": "fade_colour",
          "label": "Fade colour",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "fade_opacity",
          "label": "Fade opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "default": 70,
          "unit": "%"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bento Carousel",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
