<article class="site-page" data-template-page data-template-contact>

  <header class="page-masthead">
    <h1 class="page-title">
      {{ page.title }}
    </h1>
  </header>

  <div class="wll-contact-whatsapp">
    <a href="https://wa.me/447735018579?text=Hi%20WeLoveLEDs%2C%20I%27ve%20got%20a%20question%20about..." class="wll-contact-whatsapp__btn" target="_blank" rel="noopener noreferrer">Chat with us on WhatsApp</a>
    <p class="wll-contact-whatsapp__note">The fastest way to reach us. Adam, Gillian or Elaine are on hand during working hours (Mon to Fri, 7:45 to 16:15).</p>
    <p class="wll-contact-whatsapp__divider"><span>or use the form below</span></p>
  </div>

  {% form 'contact' %}

    {% if page.content != blank %}
      <div class="page-content rte">
        {{ page.content }}
      </div>
    {% endif %}

    <div class="contact-page-content">
      {% assign has_message = false %}

      {% if form.errors != blank %}
        {% assign has_message = true %}
        {% assign message_type = 'error' %}
      {% endif %}

      {% if form.posted_successfully? %}
        {% assign has_message = true %}
        {% assign message_type = 'success' %}
      {% endif %}

      {% if has_message %}
        <div class="contact-message message--{{ message_type }}">
          {% case message_type %}
            {% when 'success' %}
              <p>
                {{ 'contact.form.post_success' | t }}
              </p>
            {% when 'error' %}
              {{ form.errors | default_errors }}
          {% endcase %}
        </div>
      {% endif %}

      <div class="form-fields-columns">
        <div class="form-field form-field--half">
          {% assign value = '' %}
          {%- if form.name -%}
            {% assign value = form.name %}
          {%- elsif customer -%}
            {% assign value = customer.name %}
          {%- endif -%}

          <input
            class="form-field-input form-field-text {% if form.errors contains 'name' %}form-field-error{% endif %}"
            id="contact_name"
            name="contact[name]"
            type="text"
            value="{{ value }}">

          <label class="form-field-title" for="contact_name">
            {{ 'contact.form.name' | t }}
          </label>
        </div>

        <div class="form-field form-field--half">
          {% assign value = '' %}
          {%- if form.email -%}
            {% assign value = form.email %}
          {%- elsif customer -%}
            {% assign value = customer.email %}
          {%- endif -%}
          <input
            class="form-field-input form-field-text {% if form.errors contains 'email' %}form-field-error{% endif %}"
            id="contact_email"
            name="contact[email]"
            type="text"
            value="{{ value }}"
            autocorrect="off"
            autocapitalize="off">

          <label class="form-field-title" for="contact_email">
            {{ 'contact.form.email' | t }}
          </label>
        </div>
      </div>

      <div class="form-field">
        {% assign value = '' %}
        {%- if form.phone -%}
          {% assign value = form.phone %}
        {%- elsif customer -%}
          {% assign value = customer.phone %}
        {%- endif -%}

        <input
          class="form-field-input form-field-text {% if form.errors contains 'phone' %}form-field-error{% endif %}"
          id="contact_phone"
          name="contact[phone]"
          type="tel"
          value="{{ value }}">

        <label class="form-field-title" for="contact_phone">
          {{ 'contact.form.phone' | t }}
        </label>
      </div>

      <div class="form-field">
        {% assign value = '' %}

        {%- if form.body -%}
          {% assign value = form.body %}
        {%- endif -%}

        <textarea
          class="
            form-field-input
            form-field-textarea
            {% if form.errors contains 'body' %}
              form-field-error
            {% endif %}
          "
          id="contact_message"
          name="contact[message]"
        >
          {{- value -}}
        </textarea>

        <label class="form-field-title" for="contact_message">
          {{- 'contact.form.message' | t -}}
        </label>
      </div>

      <div class="form-action-row">
        <button class="button-primary contact-form-button" type="submit">
          {{ 'contact.form.send' | t }}
        </button>
      </div>
    </div>
  {% endform %}
</article>

<style>
  .wll-contact-whatsapp {
    max-width: 720px;
    margin: 32px auto 40px;
    padding: 32px 28px 24px;
    background: #f4f1f9;
    border-radius: 10px;
    border-top: 4px solid #403187;
    text-align: center;
    box-sizing: border-box;
  }
  .wll-contact-whatsapp__btn {
    display: inline-block;
    padding: 15px 32px;
    background-color: #25D366;
    color: #ffffff !important;
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    border-radius: 6px;
    box-shadow: 0 3px 10px rgba(37, 211, 102, 0.3);
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .wll-contact-whatsapp__btn:hover {
    background-color: #1ea952;
    color: #ffffff !important;
    transform: translateY(-1px);
    box-shadow: 0 5px 14px rgba(37, 211, 102, 0.4);
  }
  .wll-contact-whatsapp__note {
    margin: 16px auto 0;
    max-width: 520px;
    font-size: 14px;
    color: #403187;
    line-height: 1.55;
    opacity: 0.85;
  }
  .wll-contact-whatsapp__divider {
    margin: 24px 0 0;
    font-size: 12px;
    color: #9a92b0;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
    position: relative;
  }
  .wll-contact-whatsapp__divider span {
    background: #f4f1f9;
    padding: 0 16px;
    position: relative;
    z-index: 1;
  }
  .wll-contact-whatsapp__divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: #d8d2e6;
    z-index: 0;
  }
  @media (max-width: 768px) {
    .wll-contact-whatsapp {
      margin: 24px 16px 32px;
      padding: 24px 20px 20px;
    }
    .wll-contact-whatsapp__btn {
      padding: 13px 24px;
      font-size: 15px;
    }
  }
</style>