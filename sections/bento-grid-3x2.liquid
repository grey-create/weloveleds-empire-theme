{{ 'bento-grid-3x2.css' | asset_url | stylesheet_tag }}

<div class="bento-2x2-section" style="background-color: {{ section.settings.background_colour }};">
  <div class="bento-2x2-container">
    <div class="bento-2x2-grid" style="gap: {{ section.settings.gap_size }}px; --tile-radius: {{ section.settings.border_radius }}px; --tile-height: {{ section.settings.tile_height }}px;">
      
      {%- comment -%} Tile 1 {%- endcomment -%}
      <a href="{{ section.settings.tile_1_collection.url }}" class="bento-2x2-tile">
        <div class="bento-2x2-tile__background">
          {%- if section.settings.tile_1_image != blank -%}
            {{ section.settings.tile_1_image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'bento-2x2-tile__image' }}
          {%- endif -%}
          {%- if section.settings.tile_1_fade_to_transparent -%}
            {%- assign fade_opacity = section.settings.tile_1_fade_opacity | divided_by: 100.0 -%}
            <div class="bento-2x2-tile__overlay" style="background: linear-gradient(to top, {{ section.settings.tile_1_fade_colour | color_modify: 'alpha', fade_opacity }}, transparent); mix-blend-mode: {{ section.settings.tile_1_blend_mode }};"></div>
          {%- else -%}
            <div class="bento-2x2-tile__overlay" style="background: {{ section.settings.tile_1_overlay }}; mix-blend-mode: {{ section.settings.tile_1_blend_mode }};"></div>
          {%- endif -%}
        </div>
        <div class="bento-2x2-tile__content">
          <h2 class="bento-2x2-tile__title">
            {%- if section.settings.tile_1_title != blank -%}
              {{ section.settings.tile_1_title }}
            {%- else -%}
              {{ section.settings.tile_1_collection.title }}
            {%- endif -%}
          </h2>
          {%- if section.settings.tile_1_tagline != blank -%}
            <p class="bento-2x2-tile__tagline">{{ section.settings.tile_1_tagline }}</p>
          {%- endif -%}
          <span class="bento-2x2-tile__cta">Shop now <span class="bento-2x2-tile__arrow">→</span></span>
        </div>
      </a>

      {%- comment -%} Tile 2 {%- endcomment -%}
      <a href="{{ section.settings.tile_2_collection.url }}" class="bento-2x2-tile">
