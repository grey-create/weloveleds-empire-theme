{% schema %}
{
  "name": "Bento Grid 3x2",
  "tag": "section",
  "class": "bento-3x2-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "background_colour",
      "label": "Background colour",
      "default": "#f5f5f7"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 1400,
      "max": 2400,
      "step": 100,
      "default": 1800,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "tile_height",
      "label": "Tile height",
      "min": 280,
      "max": 500,
      "step": 20,
      "default": 380,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "gap_size",
      "label": "Gap between tiles",
      "min": 8,
      "max": 24,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 32,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Tile 1"
    },
    {
      "type": "collection",
      "id": "tile_1_collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "tile_1_title",
      "label": "Custom title"
    },
    {
      "type": "text",
      "id": "tile_1_tagline",
      "label": "Tagline"
    },
    {
      "type": "image_picker",
      "id": "tile_1_image",
      "label": "Background image"
    },
    {
      "type": "color_background",
      "id": "tile_1_overlay",
      "label": "Overlay gradient",
      "default": "linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0) 100%)"
    },
    {
      "type": "select",
      "id": "tile_1_blend_mode",
      "label": "Blend mode",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "multiply", "label": "Multiply" },
        { "value": "overlay", "label": "Overlay" },
        { "value": "soft-light", "label": "Soft Light" }
      ],
      "default": "normal"
    },
    {
      "type": "checkbox",
      "id": "tile_1_fade_to_transparent",
      "label": "Use simple fade instead",
      "default": false
    },
    {
      "type": "color",
      "id": "tile_1_fade_colour",
      "label": "Fade colour",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "tile_1_fade_opacity",
      "label": "Fade opacity",
      "min": 0,
      "max": 100,
