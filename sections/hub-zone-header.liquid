{%- liquid
  assign label = section.settings.label
  assign heading = section.settings.heading
  assign editorial = section.settings.editorial
  assign bg_colour = section.settings.bg_colour
  assign text_colour = section.settings.text_colour
  assign accent_colour = section.settings.accent_colour
  assign reveal = section.settings.reveal_on_scroll
-%}

<section class="hub-zone"
         data-section-id="{{ section.id }}"
         style="background: {{ bg_colour }}; --zone-text: {{ text_colour }}; --zone-accent: {{ accent_colour }};">
  <div class="hub-zone__container{% if reveal %} hub-zone--reveal{% endif %}">
    {%- if label != blank -%}
      <p class="hub-zone__label">{{ label | escape }}</p>
    {%- endif -%}
    {%- if heading != blank -%}
      <h2 class="hub-zone__heading">
        <span class="hub-zone__heading-bold">{{ heading | escape }}</span>{%- if editorial != blank %} <span class="hub-zone__heading-muted">{{ editorial | escape }}</span>{%- endif -%}
      </h2>
    {%- endif -%}
  </div>
</section>

<style>
.hub-zone {
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  padding: 2.5rem 1.5rem 1.5rem;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
}
.hub-zone__container {
  padding-left: var(--hub-rail-pad);
  padding-right: var(--hub-rail-pad);
}

/* Eyebrow tag — minimal, no pill, no dot */
.hub-zone__label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--zone-accent, #d946ef);
  margin: 0 0 1rem;
}

/* Heading: bold statement + muted continuation, inline */
.hub-zone__heading {
  font-size: clamp(1.25rem, 2vw, 1.625rem);
  font-weight: 600;
  letter-spacing: -0.025em;
  line-height: 1.2;
  margin: 0;
}
.hub-zone__heading-bold {
  color: var(--zone-text, #1c2135);
  font-weight: 600;
}
.hub-zone__heading-muted {
  color: #6e6e73;
  font-weight: 400;
}

.hub-zone--reveal { transform: translateY(24px); transition: transform 0.7s ease; }
.hub-zone--reveal.is-revealed { transform: translateY(0); }

@media (max-width: 749px) {
  .hub-zone { padding: 2rem 1.25rem 1.75rem; }
  .hub-zone__container { padding: 0 0.5rem; }
  .hub-zone__label { margin-bottom: 0.75rem; }
}
@media (prefers-reduced-motion: reduce) {
  .hub-zone--reveal { transform: none; transition: none; }
}
</style>

<script>
(function() {
  if (window.__hubZoneObserver) return;
  if (!('IntersectionObserver' in window)) return;
  window.__hubZoneObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-revealed');
        window.__hubZoneObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.hub-zone--reveal').forEach(function(el) {
      window.__hubZoneObserver.observe(el);
    });
  });
})();
</script>

{% schema %}
{
  "name": "Hub Zone Header",
  "tag": "section",
  "class": "section-hub-zone",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow tag", "default": "BROWSE", "info": "Tiny uppercase tag above heading (e.g. BROWSE / DECIDE / RESEARCH). Leave blank to hide." },
    { "type": "text", "id": "heading", "label": "Bold statement", "default": "Having a browse.", "info": "Short confident phrase ending in a period." },
    { "type": "textarea", "id": "editorial", "label": "Muted descriptor", "info": "Continuation text shown in lighter grey, inline with the heading." },
    { "type": "color", "id": "bg_colour", "label": "Background colour", "default": "#f5f5f7" },
    { "type": "color", "id": "text_colour", "label": "Heading colour", "default": "#1c2135" },
    { "type": "color", "id": "accent_colour", "label": "Eyebrow accent colour", "default": "#0076DE" },
    { "type": "checkbox", "id": "reveal_on_scroll", "label": "Fade in on scroll", "default": true }
  ],
  "presets": [ { "name": "Hub Zone Header" } ]
}
{% endschema %}
