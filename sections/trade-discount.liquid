      <p class="trade-subtitle">Join 8,000+ sign makers, electricians, and lighting professionals who save on every purchase with our exclusive trade discount.</p>
    </div>
  </div>
  
  <!-- Main Content -->
  <div class="trade-main">
    <div class="trade-container">
      
      <!-- Left Column: Benefits -->
      <div class="trade-benefits">
        <h2 class="benefits-heading">What You'll Get</h2>
        
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                <line x1="7" y1="7" x2="7.01" y2="7"/>
              </svg>
            </div>
            <h3>10% Off Every Order</h3>
            <p>Your exclusive discount code works on everything, every time. No minimum order, no expiry.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <h3>Trade-Only Offers</h3>
            <p>Be the first to hear about bulk deals, new product launches, and exclusive promotions.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <h3>Priority Support</h3>
            <p>Direct access to our technical team for product advice and project support.</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="1" y="3" width="15" height="13"/>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            </div>
            <h3>Free UK Shipping</h3>
            <p>All orders ship free across the UK, with next-day delivery available.</p>
          </div>
        </div>
        
        <!-- Trust Elements -->
        <div class="trade-trust">
          <p class="trust-label">Trusted by professionals across the UK</p>
          <div class="trust-pills">
            <span class="trust-pill">✓ Sign Makers</span>
            <span class="trust-pill">✓ Electricians</span>
            <span class="trust-pill">✓ Display Companies</span>
            <span class="trust-pill">✓ Event Production</span>
          </div>
        </div>
      </div>
      
      <!-- Right Column: Signup Form -->
      <div class="trade-form-wrapper">
        <div class="trade-form-card">
          <h2>Sign Up for Your Trade Discount</h2>
          <p class="form-intro">Complete the form below and we'll send your exclusive 10% discount code straight to your inbox.</p>
          
          <!-- Klaviyo Form -->
          <form id="trade-signup-form" class="trade-form">
            
            <div class="form-group">
              <label for="first_name">First Name <span class="required">*</span></label>
              <input type="text" id="first_name" name="first_name" required placeholder="Your first name">
            </div>
            
            <div class="form-group">
              <label for="email">Email Address <span class="required">*</span></label>
              <input type="email" id="email" name="email" required placeholder="your@email.com">
            </div>
            
            <div class="form-group">
              <label for="company">Company Name <span class="required">*</span></label>
              <input type="text" id="company" name="company" required placeholder="Your company name">
            </div>
            
            <div class="form-group">
              <label for="trade_type">Trade Type <span class="required">*</span></label>
              <select id="trade_type" name="trade_type" required>
                <option value="">Select your trade...</option>
                <option value="Sign Maker">Sign Maker / Signage Company</option>
                <option value="Electrician">Electrician / Electrical Contractor</option>
                <option value="Display & Exhibition">Display & Exhibition</option>
                <option value="Event Production">Event Production</option>
                <option value="Shop Fitting">Shop Fitting / Retail</option>
                <option value="Architect / Designer">Architect / Interior Designer</option>
                <option value="Fairground / Amusement">Fairground / Amusement</option>
                <option value="Film & TV">Film & TV Production</option>
                <option value="Installer">General Installer</option>
                <option value="Reseller">Reseller / Distributor</option>
                <option value="Other">Other Trade Professional</option>
              </select>
            </div>
            
            <button type="submit" class="trade-submit-btn">
              <span class="btn-text">Get My 10% Discount Code</span>
              <span class="btn-arrow">→</span>
            </button>
            
            <p class="form-privacy">We respect your privacy. Unsubscribe anytime.</p>
          </form>

          <!-- Success Message -->
          <div id="trade-success" class="trade-success" style="display: none;">
            <div class="success-icon">✓</div>
            <h3>You're almost there!</h3>
            <p>Check your inbox for a confirmation email. Click the link to verify and we'll send your 10% discount code.</p>
            <p class="success-note">Not there? Check spam or contact <a href="mailto:sales@weloveleds.co.uk">sales@weloveleds.co.uk</a></p>
          </div>
        </div>
        
        <!-- FAQ -->
        <div class="trade-faq">
          <h3>Quick Questions</h3>
          
          <details class="faq-item">
            <summary>How does the discount work?</summary>
            <p>After confirming your email, you'll receive a unique discount code. Enter it at checkout to get 10% off your order total. Use it as many times as you like!</p>
          </details>
          
          <details class="faq-item">
            <summary>Is there a minimum order?</summary>
            <p>No minimum order required. Your discount works on orders of any size.</p>
          </details>
          
          <details class="faq-item">
            <summary>Do I need to prove I'm a trade customer?</summary>
            <p>No verification needed. We trust our customers, and this discount is our way of supporting professionals in the industry.</p>
          </details>
          
          <details class="faq-item">
            <summary>Can I combine this with other offers?</summary>
            <p>The trade discount can't be combined with other promotional codes, but it does work alongside our free shipping and bulk pricing.</p>
          </details>
        </div>
        
      </div>
      
    </div>
  </div>
  
</div>

<script>
document.getElementById('trade-signup-form').addEventListener('submit', function(e) {
  e.preventDefault();
  
  var form = this;
  var btn = form.querySelector('.trade-submit-btn');
  var btnText = btn.querySelector('.btn-text');
  
  var email = form.querySelector('#email').value;
  var firstName = form.querySelector('#first_name').value;
  var company = form.querySelector('#company').value;
  var tradeType = form.querySelector('#trade_type').value;
  
  btnText.textContent = 'Sending...';
  btn.disabled = true;
  
  fetch('https://a.klaviyo.com/client/subscriptions/?company_id=VuRsCE', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'revision': '2024-02-15'
    },
    body: JSON.stringify({
      data: {
        type: 'subscription',
        attributes: {
          custom_source: 'Trade Discount Page',
          profile: {
            data: {
              type: 'profile',
              attributes: {
                email: email,
                first_name: firstName,
                organization: company,
                properties: {
                  trade_type: tradeType
                }
              }
            }
          }
        },
        relationships: {
          list: {
            data: {
              type: 'list',
              id: 'UNpDKm'
            }
          }
        }
      }
    })
  })
  .then(function(response) {
    form.style.display = 'none';
    document.getElementById('trade-success').style.display = 'block';
  })
  .catch(function(error) {
    console.error('Error:', error);
    btnText.textContent = 'Get My 10% Discount Code';
    btn.disabled = false;
    alert('Something went wrong. Please try again or contact sales@weloveleds.co.uk');
  });
});
</script>

