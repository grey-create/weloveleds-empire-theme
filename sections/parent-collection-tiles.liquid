{% assign menu = linklists[collection.handle] %}

{% if menu.links.size > 0 %}

{%- liquid
  assign pct_eyebrow = section.settings.eyebrow
  assign pct_heading = section.settings.heading | default: collection.title
  assign bg_colour = section.settings.bg_colour
  assign heading_colour = section.settings.heading_colour
  assign accent_colour = section.settings.accent_colour
  assign scrim_colour = section.settings.scrim_colour
  assign reveal = section.settings.reveal_on_scroll
  assign link_count = menu.links.size
-%}

<div class="pct-section"
     data-section-id="{{ section.id }}"
     style="background: {{ bg_colour }}; --pct-accent: {{ accent_colour }}; --pct-heading: {{ heading_colour }}; --pct-scrim: {{ scrim_colour }};">
  <div class="pct-head">
    <div class="pct-headings">
      {% if pct_eyebrow != blank %}<p class="pct-eyebrow">{{ pct_eyebrow }}</p>{% endif %}
      {% if pct_heading != blank %}<h2 class="pct-heading">{{ pct_heading }}</h2>{% endif %}
    </div>
    <div class="pct-nav">
      <button class="pct-arrow pct-arrow--prev" aria-label="Previous"><span aria-hidden="true">&#8592;</span></button>
      <button class="pct-arrow pct-arrow--next" aria-label="Next"><span aria-hidden="true">&#8594;</span></button>
    </div>
  </div>

  <div class="pct-track{% if reveal %} pct-reveal{% endif %}" id="pct-track-{{ section.id }}">
    {% for link in menu.links %}
      {% assign pos = forloop.index %}

      {% for block in section.blocks %}
        {% if block.type == 'custom_tile' and block.settings.position == pos %}
          {% render 'pct-custom-tile', block: block %}
        {% endif %}
      {% endfor %}

      {% assign child = link.object %}
      {% if child %}
        {% assign tile_image = '' %}
        {% if child.image %}
          {% assign tile_image = child.image | img_url: '600x' %}
        {% elsif child.products.first.featured_image %}
          {% assign tile_image = child.products.first.featured_image | img_url: '600x' %}
        {% endif %}

        {% assign tile_title = child.metafields.custom.tile_title | default: child.title %}
        {% assign tile_desc = child.metafields.custom.tile_description %}

        <a href="{{ link.url }}" class="pct-tile">
          <div class="pct-tile__image-wrap">
            {% if tile_image != '' %}
              <img src="{{ tile_image }}" alt="{{ tile_title | escape }}" class="pct-tile__image" loading="lazy">
            {% else %}
              <div class="pct-tile__placeholder"></div>
            {% endif %}
            <div class="pct-tile__scrim"></div>
          </div>
          <div class="pct-tile__text">
            <h3 class="pct-tile__title">{{ tile_title }}</h3>
            {% if tile_desc != blank %}<p class="pct-tile__desc">{{ tile_desc }}</p>{% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}

    {% for block in section.blocks %}
      {% if block.type == 'custom_tile' %}
        {% if block.settings.position == 0 or block.settings.position > link_count %}
          {% render 'pct-custom-tile', block: block %}
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>
</div>

<style>
.pct-section {
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  background: var(--wll-bg, #f5f5f7);
  padding: 2.5rem 0 3rem;
  font-family: var(--wll-font, 'Inter', -apple-system, BlinkMacSystemFont, sans-serif);
  box-sizing: border-box;
}
.pct-head {
  padding-left: var(--wll-rail, clamp(1.5rem, 8vw, 200px));
  padding-right: var(--wll-rail, clamp(1.5rem, 8vw, 200px));
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.25rem;
}
.pct-eyebrow {
  font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
  letter-spacing: var(--wll-tracking-eyebrow, 0.14em);
  color: var(--pct-accent, var(--wll-accent-blue, #0076DE));
  margin: 0 0 0.5rem;
}
.pct-heading {
  font-size: clamp(1.25rem, 2vw, 1.625rem); font-weight: 600;
  letter-spacing: var(--wll-tracking-tight, -0.025em);
  color: var(--pct-heading, var(--wll-text, #1B2034));
  line-height: 1.2; margin: 0;
}
.pct-nav { display: flex; gap: 0.5rem; flex: 0 0 auto; }
.pct-arrow {
  width: 40px; height: 40px; border-radius: 999px; background: #fff;
  border: 1px solid var(--wll-card-border, rgba(28,33,53,0.12));
  color: var(--wll-text, #1B2034); font-size: 1.1rem; line-height: 1; cursor: pointer;
  display: flex; align-items: center; justify-content: center; padding: 0;
  transition: border-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
}
.pct-arrow:hover { border-color: var(--pct-accent, var(--wll-accent-blue, #0076DE)); color: var(--pct-accent, var(--wll-accent-blue, #0076DE)); }
.pct-arrow:active { transform: scale(0.95); }
.pct-arrow:disabled { opacity: 0.35; cursor: not-allowed; }

.pct-track {
  display: flex; gap: 1.25rem; margin: 0;
  overflow-x: auto; overflow-y: hidden;
  scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none;
  scroll-behavior: smooth;
  padding: 1rem var(--wll-rail, clamp(1.5rem, 8vw, 200px)) 2rem;
  padding-right: 1.5rem;
  scroll-padding-left: var(--wll-rail, clamp(1.5rem, 8vw, 200px));
}
.pct-track::-webkit-scrollbar { display: none; }

.pct-reveal { transform: translateY(24px); transition: transform 0.7s ease; }
.pct-reveal.is-revealed { transform: translateY(0); }

.pct-tile {
  flex: 0 0 clamp(153px, 13vw, 227px);
  scroll-snap-align: start; position: relative; display: block; aspect-ratio: 1 / 1;
  border-radius: var(--wll-radius-card, 22px); overflow: hidden; text-decoration: none;
  background: transparent;
  box-shadow: var(--wll-shadow-rest, 0 1px 3px rgba(28,33,53,0.04), 0 4px 10px rgba(28,33,53,0.05));
  transition: transform 0.25s var(--wll-ease, cubic-bezier(0.4,0,0.2,1)), box-shadow 0.25s ease;
}
.pct-tile:hover { transform: translateY(-4px); box-shadow: var(--wll-shadow-hover, 0 2px 6px rgba(28,33,53,0.05), 0 6px 14px rgba(28,33,53,0.08)); }
.pct-tile__image-wrap { position: absolute; inset: 0; overflow: hidden; border-radius: var(--wll-radius-card, 22px); }
.pct-tile__image { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; transition: transform 0.4s var(--wll-ease, cubic-bezier(0.4,0,0.2,1)); }
.pct-tile:hover .pct-tile__image { transform: scale(1.04); }
.pct-tile__placeholder { position: absolute; inset: 0; background: linear-gradient(135deg, #0a1530 0%, #1c2135 55%, #1d2236 100%); }
.pct-tile__placeholder--accent { background: var(--pct-tile-accent, #0a1530); }
.pct-tile__scrim {
  position: absolute; inset: 0;
  background: linear-gradient(to top,
    color-mix(in srgb, var(--pct-scrim, #0a1530) 88%, transparent) 0%,
    color-mix(in srgb, var(--pct-scrim, #0a1530) 40%, transparent) 36%,
    transparent 68%);
}
.pct-tile__text { position: absolute; left: 0; right: 0; bottom: 0; padding: 1.1rem 1.15rem; z-index: 1; }
.pct-tile__eyebrow { display: block; font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.85); margin: 0 0 0.35rem; }
.pct-tile__title { color: #fff; font-size: 1.0625rem; font-weight: 600; letter-spacing: var(--wll-tracking-snug, -0.018em); line-height: 1.2; margin: 0; }
.pct-tile__desc {
  color: rgba(255,255,255,0.82); font-size: 0.8125rem; line-height: 1.3; margin: 0.35rem 0 0;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.pct-tile__badge {
  position: absolute; top: 0.75rem; left: 0.75rem; z-index: 2;
  background: var(--pct-tile-accent, #0076DE); color: #fff;
  font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
  padding: 4px 9px; border-radius: 999px;
}

@media (max-width: 990px) { .pct-nav { display: none; } }
@media (max-width: 600px) {
  .pct-section { padding: 2rem 0 2.5rem; }
  .pct-head { padding-left: 1.25rem; padding-right: 1.25rem; margin-bottom: 1rem; }
  .pct-track { padding: 1rem 1.25rem 1.75rem; scroll-padding-left: 1.25rem; }
  .pct-tile { flex-basis: clamp(122px, 36vw, 170px); border-radius: var(--wll-radius-card-mobile, 18px); }
}
@media (prefers-reduced-motion: reduce) {
  .pct-tile, .pct-tile__image { transition: none; }
  .pct-reveal { transform: none; transition: none; }
}
</style>

<script>
(function() {
  var track = document.getElementById('pct-track-{{ section.id }}');
  if (!track) return;
  var section = track.closest('.pct-section');
  var prevBtn = section.querySelector('.pct-arrow--prev');
  var nextBtn = section.querySelector('.pct-arrow--next');

  function getScrollAmount() {
    var tile = track.querySelector('.pct-tile');
    return tile ? tile.offsetWidth + 20 : 240;
  }
  function updateArrows() {
    if (!prevBtn || !nextBtn) return;
    prevBtn.disabled = track.scrollLeft <= 2;
    nextBtn.disabled = track.scrollLeft + track.offsetWidth >= track.scrollWidth - 2;
  }
  if (prevBtn) prevBtn.addEventListener('click', function() { track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' }); });
  if (nextBtn) nextBtn.addEventListener('click', function() { track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' }); });
  track.addEventListener('scroll', updateArrows);
  updateArrows();

  if (track.classList.contains('pct-reveal') && 'IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) { entry.target.classList.add('is-revealed'); io.unobserve(entry.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    io.observe(track);
  }
})();
</script>

{% endif %}

{% schema %}
{
  "name": "Parent Collection Tiles",
  "max_blocks": 8,
  "settings": [
    { "type": "header", "content": "Heading row" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow tag", "default": "BROWSE THE RANGE", "info": "Tiny uppercase label above the heading. Leave blank to hide." },
    { "type": "text", "id": "heading", "label": "Heading", "info": "Defaults to this collection's title if left blank." },
    { "type": "header", "content": "Colours & gradient" },
    { "type": "color", "id": "bg_colour", "label": "Section background", "default": "#f5f5f7" },
    { "type": "color", "id": "heading_colour", "label": "Heading colour", "default": "#1B2034" },
    { "type": "color", "id": "accent_colour", "label": "Accent (eyebrow + arrows)", "default": "#0076DE" },
    { "type": "color", "id": "scrim_colour", "label": "Card gradient colour", "default": "#0a1530", "info": "The gradient over each card image that keeps the title readable." },
    { "type": "checkbox", "id": "reveal_on_scroll", "label": "Fade in on scroll", "default": true }
  ],
  "blocks": [
    {
      "type": "custom_tile",
      "name": "Bespoke tile",
      "settings": [
        { "type": "paragraph", "content": "A custom tile mixed in with the auto category tiles — for a promo, upsell, or a link elsewhere on the site." },
        { "type": "image_picker", "id": "image", "label": "Image", "info": "Optional. If blank, the accent colour fills the tile." },
        { "type": "text", "id": "badge", "label": "Corner badge", "info": "e.g. OFFER, NEW. Leave blank to hide." },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "title", "label": "Title", "default": "Custom tile" },
        { "type": "text", "id": "description", "label": "Description" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "color", "id": "accent_colour", "label": "Accent colour", "default": "#0076DE", "info": "Colours the badge and the no-image background." },
        { "type": "range", "id": "position", "label": "Insert at position", "min": 0, "max": 20, "step": 1, "default": 0, "info": "1 = before the first tile, 2 = before the second, and so on. 0 = at the end." }
      ]
    }
  ]
}
{% endschema %}
