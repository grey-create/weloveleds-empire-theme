{%- liquid
  assign heading = section.settings.heading
  assign subtitle = section.settings.subtitle
  assign btn1_label = section.settings.btn1_label
  assign btn1_url = section.settings.btn1_url
  assign btn2_label = section.settings.btn2_label
  assign btn2_url = section.settings.btn2_url
  assign btn3_label = section.settings.btn3_label
  assign btn3_url = section.settings.btn3_url
  assign use_collection_title = section.settings.use_collection_title
-%}

<section class="hub-hero" data-section-id="{{ section.id }}">
  <div class="hub-hero__container">
    <div class="hub-hero__inner">
      <h1 class="hub-hero__heading">
        {%- if use_collection_title -%}
          {{ collection.title | escape }}
        {%- else -%}
          {{ heading | escape }}
        {%- endif -%}
      </h1>
      {%- if subtitle != blank -%}
        <p class="hub-hero__subtitle">{{ subtitle | escape }}</p>
      {%- endif -%}

      <div class="hub-hero__buttons">
        {%- if btn1_label != blank -%}
          <a href="{{ btn1_url | default: '#' }}" class="hub-hero__btn hub-hero__btn--primary">
            {{ btn1_label | escape }}
          </a>
        {%- endif -%}
        {%- if btn2_label != blank -%}
          <a href="{{ btn2_url | default: '#' }}" class="hub-hero__btn hub-hero__btn--secondary">
            {{ btn2_label | escape }}
          </a>
        {%- endif -%}
        {%- if btn3_label != blank -%}
          <a href="{{ btn3_url | default: '#' }}"
             class="hub-hero__btn hub-hero__btn--ghost{% if btn3_url contains 'wa.me' %} hub-hero__btn--whatsapp{% endif %}"
             {%- if btn3_url contains 'wa.me' %} target="_blank" rel="noopener noreferrer"{% endif -%}>
            {%- if btn3_url contains 'wa.me' -%}
              <svg class="hub-hero__btn-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/>
              </svg>
            {%- endif -%}
            {{ btn3_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
.hub-hero {
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  background-color: #1c2135;
  background-image: linear-gradient(135deg, #0a1530 0%, #1c2135 50%, #1d2236 100%);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  overflow: hidden;
  position: relative;
}
.hub-hero::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -10%;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(217, 70, 239, 0.12) 0%, rgba(217, 70, 239, 0) 70%);
  pointer-events: none;
}
.hub-hero::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(0, 118, 222, 0.15) 0%, rgba(0, 118, 222, 0) 70%);
  pointer-events: none;
}
.hub-hero__container {
  padding: 3rem calc(var(--hub-rail-pad) + 1.5rem);
  position: relative;
  z-index: 1;
}
.hub-hero__inner {
  max-width: 820px;
}
.hub-hero__heading {
  font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  font-weight: 600;
  color: #ffffff;
  margin: 0 0 1.5rem;
  letter-spacing: -0.025em;
  line-height: 1.05;
}
.hub-hero__subtitle {
  font-size: clamp(1.125rem, 1.8vw, 1.375rem);
  font-weight: 400;
  color: rgba(255, 255, 255, 0.78);
  margin: 0 0 2.5rem;
  line-height: 1.5;
  max-width: 680px;
}
.hub-hero__buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 0.875rem;
}
.hub-hero__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.9375rem 1.75rem;
  border-radius: 999px;
  font-size: 1rem;
  font-weight: 600;
  text-decoration: none;
  transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
  letter-spacing: -0.005em;
}
.hub-hero__btn--primary {
  background: #ffffff;
  color: #1c2135;
}
.hub-hero__btn--primary:hover {
  background: #fdcd6a;
  color: #1c2135;
  transform: translateY(-2px);
}
.hub-hero__btn--secondary {
  background: #fdcd6a;
  color: #1c2135;
}
.hub-hero__btn--secondary:hover {
  background: #ffffff;
  color: #1c2135;
  transform: translateY(-2px);
}
.hub-hero__btn--ghost {
  background: transparent;
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.4);
}
.hub-hero__btn--ghost:hover {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.7);
  transform: translateY(-2px);
}
.hub-hero__btn--whatsapp {
  background: #25D366;
  color: #ffffff;
  border-color: #25D366;
}
.hub-hero__btn--whatsapp:hover {
  background: #1ebe57;
  border-color: #1ebe57;
  color: #ffffff;
}
.hub-hero__btn-icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  margin-right: 0.5rem;
}
@media (max-width: 749px) {
  .hub-hero__container { padding: 2rem 1.25rem 1.75rem; }
  .hub-hero__subtitle { margin-bottom: 2rem; }
  .hub-hero__buttons { flex-direction: column; align-items: stretch; }
  .hub-hero__btn { padding: 0.875rem 1.5rem; }
}
</style>

{% schema %}
{
  "name": "Hub Hero",
  "tag": "section",
  "class": "section-hub-hero",
  "settings": [
    { "type": "checkbox", "id": "use_collection_title", "label": "Use collection title as heading", "default": true },
    { "type": "text", "id": "heading", "label": "Custom heading (if not using collection title)" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Complete kits, replacement bulbs, cabochon components and colour-changing systems. UK stock. Next-day delivery." },
    { "type": "header", "content": "Button 1 — Primary" },
    { "type": "text", "id": "btn1_label", "label": "Button 1 label", "default": "Shop Kits" },
    { "type": "url", "id": "btn1_url", "label": "Button 1 URL" },
    { "type": "header", "content": "Button 2 — Accent" },
    { "type": "text", "id": "btn2_label", "label": "Button 2 label", "default": "Shop Bulbs" },
    { "type": "url", "id": "btn2_url", "label": "Button 2 URL" },
    { "type": "header", "content": "Button 3 — Ghost (use for WhatsApp / external)" },
    { "type": "text", "id": "btn3_label", "label": "Button 3 label", "default": "Need Help Choosing?" },
    { "type": "url", "id": "btn3_url", "label": "Button 3 URL (wa.me links open in new tab)" }
  ],
  "presets": [ { "name": "Hub Hero" } ]
}
{% endschema %}
