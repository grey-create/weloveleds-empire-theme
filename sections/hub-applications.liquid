{% comment %}
  Hub: Applications
  Auto-fit grid of application cards (where these products end up being used).
  Block-based: each block has icon + title + description.
  Designed to match the Choose Route / Bestsellers / Decide chassis.
{% endcomment %}

{%- liquid
  assign section_id = 'hub-applications-' | append: section.id
  assign reveal = section.settings.reveal_animation
  assign bg_colour = section.settings.bg_colour
  assign accent_colour = section.settings.accent_colour
-%}

<section class="hub-applications"
         id="{{ section_id }}"
         data-zone="research"
         style="background: {{ bg_colour }}; --zone-accent: {{ accent_colour }};">
  <div class="hub-applications__container{% if reveal %} hub-applications--reveal{% endif %}">

    {%- if section.settings.row_label != blank -%}
      <div class="hub-applications__row-head">
        <p class="hub-applications__row-label">{{ section.settings.row_label }}</p>
      </div>
    {%- endif -%}

    <ul class="hub-applications__grid" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'application' -%}
          <li class="hub-applications__item" {{ block.shopify_attributes }}>
            <article class="hub-applications__card">
              {%- if block.settings.icon != blank -%}
                <i class="ti {{ block.settings.icon }} hub-applications__icon" aria-hidden="true"></i>
              {%- endif -%}
              <h3 class="hub-applications__title">{{ block.settings.title }}</h3>
              {%- if block.settings.description != blank -%}
                <p class="hub-applications__description">{{ block.settings.description }}</p>
              {%- endif -%}
              {%- if block.settings.cta_url != blank -%}
                <a href="{{ block.settings.cta_url }}" class="hub-applications__cta">
                  {{ block.settings.cta_label | default: 'Learn more' }}
                  <span class="hub-applications__cta-arrow" aria-hidden="true">→</span>
                </a>
              {%- endif -%}
            </article>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>
</section>

<style>
  .hub-applications {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    padding: 0 1.5rem 4rem;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .hub-applications__container {
    padding-left: var(--hub-rail-pad);
    padding-right: var(--hub-rail-pad);
  }

  .hub-applications__row-head {
    margin-bottom: 1.25rem;
  }
  .hub-applications__row-label {
    font-size: 1rem;
    font-weight: 500;
    color: #1c2135;
    margin: 0;
  }

  .hub-applications__grid {
    list-style: none;
    margin: 0;
    padding: 1rem 0 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .hub-applications__card {
    background: #ffffff;
    border-radius: 18px;
    border: 1px solid rgba(28, 33, 53, 0.06);
    box-shadow: 0 1px 3px rgba(28, 33, 53, 0.04), 0 4px 10px rgba(28, 33, 53, 0.05);
    padding: 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s ease;
  }
  .hub-applications__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 2px 6px rgba(28, 33, 53, 0.05), 0 6px 14px rgba(28, 33, 53, 0.08);
  }

  .hub-applications__icon {
    font-size: 24px;
    color: var(--zone-accent, #c98e0a);
    margin-bottom: 0.875rem;
    display: inline-block;
  }
  .hub-applications__title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: #1c2135;
    line-height: 1.3;
    margin: 0 0 0.5rem;
    letter-spacing: -0.005em;
  }
  .hub-applications__description {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: #1c2135;
    margin: 0;
    flex: 1;
  }
  .hub-applications__cta {
    margin-top: 1rem;
    text-decoration: none;
    color: var(--zone-accent, #c98e0a);
    font-size: 0.875rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    align-self: flex-start;
    transition: opacity 0.2s ease;
  }
  .hub-applications__cta:hover {
    opacity: 0.75;
  }
  .hub-applications__cta:hover .hub-applications__cta-arrow {
    transform: translateX(2px);
  }
  .hub-applications__cta-arrow {
    transition: transform 0.2s ease;
  }

  .hub-applications--reveal {
    transform: translateY(24px);
    transition: transform 0.7s ease;
  }
  .hub-applications--reveal.is-revealed {
    transform: translateY(0);
  }

  @media (max-width: 600px) {
    .hub-applications { padding: 0 1.25rem 2.5rem; }
    .hub-applications__card { padding: 1.25rem; border-radius: 16px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-applications--reveal { transform: none; transition: none; }
    .hub-applications__card,
    .hub-applications__cta-arrow { transition: none; }
  }
</style>

<script>
  (function() {
    var section = document.getElementById('{{ section_id }}');
    if (!section) return;

    var revealEl = section.querySelector('.hub-applications--reveal');
    if (revealEl) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            revealEl.classList.add('is-revealed');
            observer.unobserve(revealEl);
          }
        });
      }, { threshold: 0.1 });
      observer.observe(revealEl);
    }
  })();
</script>

{% schema %}
{
  "name": "Hub: Applications",
  "tag": "section",
  "class": "hub-applications-section",
  "settings": [
    {
      "type": "header",
      "content": "Section settings"
    },
    {
      "type": "text",
      "id": "row_label",
      "label": "Row heading (optional)",
      "info": "Small label above the grid. Leave blank if the zone header above does the job."
    },
    {
      "type": "checkbox",
      "id": "reveal_animation",
      "label": "Slide-up animation on scroll",
      "default": true
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_colour",
      "label": "Section background",
      "default": "#f5f5f7"
    },
    {
      "type": "color",
      "id": "accent_colour",
      "label": "Zone accent (icon, CTAs, eyebrow)",
      "info": "Research zone accent is amber (#c98e0a)",
      "default": "#c98e0a"
    }
  ],
  "blocks": [
    {
      "type": "application",
      "name": "Application card",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Tabler icon name (optional)",
          "info": "e.g. ti-bulb, ti-building-store, ti-sparkles. Leave blank for no icon. Browse: https://tabler.io/icons",
          "default": "ti-building-store"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Application title",
          "default": "Illuminated Signage"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "info": "2–3 sentences explaining where this product is used.",
          "default": "Fascia signs, retail shopfronts, pub and bar signage — cabochons deliver bold, bright lettering with low energy costs."
        },
        {
          "type": "header",
          "content": "Optional CTA"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Link URL"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Link text",
          "default": "Learn more"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Hub: Applications",
      "blocks": [
        { "type": "application" },
        { "type": "application" },
        { "type": "application" },
        { "type": "application" },
        { "type": "application" },
        { "type": "application" }
      ]
    }
  ]
}
{% endschema %}
