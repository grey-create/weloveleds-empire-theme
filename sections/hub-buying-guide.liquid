{% comment %}
  Hub: Quick Questions
  CSS Grid of Q&A cards. Each card is a button that opens a focus-managed modal
  with the full answer. Block-based: one block = one question.
{% endcomment %}

{%- liquid
  assign section_id = 'hub-questions-' | append: section.id
  assign reveal = section.settings.reveal_animation
  assign bg_colour = section.settings.bg_colour
  assign accent_colour = section.settings.accent_colour
  assign heading = section.settings.heading
  assign eyebrow = section.settings.eyebrow | default: 'Q&A'
-%}

<section class="hub-questions"
         id="{{ section_id }}"
         data-zone="decide"
         style="background: {{ bg_colour }}; --zone-accent: {{ accent_colour }};">
  <div class="hub-questions__container{% if reveal %} hub-questions--reveal{% endif %}">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="hub-questions__head">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hub-questions__head-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="hub-questions__head-title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="hub-questions__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'question' -%}
          {%- if block.settings.question == blank -%}
            {%- continue -%}
          {%- endif -%}

          {%- liquid
            case block.settings.accent_color
              when 'blue'
                assign icon_bg = '#0076DE'
                assign text_fill = '#0076DE'
                assign eyebrow_color = '#0076DE'
                assign is_grad = false
              when 'yellow'
                assign icon_bg = '#fdcd6a'
                assign text_fill = '#c98a10'
                assign eyebrow_color = '#fdcd6a'
                assign is_grad = false
              when 'navy'
                assign icon_bg = '#1B2034'
                assign text_fill = '#1B2034'
                assign eyebrow_color = '#1B2034'
                assign is_grad = false
              when 'green'
                assign icon_bg = '#10b981'
                assign text_fill = '#10b981'
                assign eyebrow_color = '#10b981'
                assign is_grad = false
              when 'orange'
                assign icon_bg = '#f97316'
                assign text_fill = '#f97316'
                assign eyebrow_color = '#f97316'
                assign is_grad = false
              when 'grad_magenta_blue'
                assign icon_bg = 'linear-gradient(135deg, #d946ef, #0076DE)'
                assign text_fill = 'linear-gradient(135deg, #b81fd4, #0076DE)'
                assign eyebrow_color = '#d946ef'
                assign is_grad = true
              when 'grad_blue_navy'
                assign icon_bg = 'linear-gradient(135deg, #0076DE, #1B2034)'
                assign text_fill = 'linear-gradient(135deg, #0076DE, #1B2034)'
                assign eyebrow_color = '#0076DE'
                assign is_grad = true
              when 'grad_green_blue'
                assign icon_bg = 'linear-gradient(135deg, #10b981, #0076DE)'
                assign text_fill = 'linear-gradient(135deg, #0c875f, #0076DE)'
                assign eyebrow_color = '#10b981'
                assign is_grad = true
              when 'grad_yellow_orange'
                assign icon_bg = 'linear-gradient(135deg, #fdcd6a, #f97316)'
                assign text_fill = 'linear-gradient(135deg, #c98a10, #d9620e)'
                assign eyebrow_color = '#fdcd6a'
                assign is_grad = true
              when 'grad_magenta_orange'
                assign icon_bg = 'linear-gradient(135deg, #d946ef, #f97316)'
                assign text_fill = 'linear-gradient(135deg, #b81fd4, #d9620e)'
                assign eyebrow_color = '#d946ef'
                assign is_grad = true
              when 'grad_navy_blue'
                assign icon_bg = 'linear-gradient(135deg, #1B2034, #0076DE)'
                assign text_fill = 'linear-gradient(135deg, #1B2034, #0076DE)'
                assign eyebrow_color = '#1B2034'
                assign is_grad = true
              else
                assign icon_bg = '#d946ef'
                assign text_fill = '#d946ef'
                assign eyebrow_color = '#d946ef'
                assign is_grad = false
            endcase
            assign modal_id = 'qmodal-' | append: section.id | append: '-' | append: block.id
          -%}

          {%- if is_grad -%}
            {%- capture q_style -%}color:#1B2034;background:{{ text_fill }};-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;{%- endcapture -%}
          {%- else -%}
            {%- capture q_style -%}color:{{ text_fill }};{%- endcapture -%}
          {%- endif -%}

          <button type="button"
                  class="hub-questions__card"
                  data-modal-trigger="{{ modal_id }}"
                  aria-haspopup="dialog"
                  {{ block.shopify_attributes }}>
            <span class="hub-questions__eyebrow" style="color:{{ eyebrow_color }};">{{ eyebrow }}</span>
            <div class="hub-questions__main">
              <span class="hub-questions__icon-wrap" style="background:{{ icon_bg }};">
                {%- render 'lucide-icon', icon: block.settings.icon -%}
              </span>
              <h3 class="hub-questions__question" style="{{ q_style }}">{{ block.settings.question | escape }}</h3>
            </div>
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

  {%- for block in section.blocks -%}
    {%- if block.type == 'question' and block.settings.question != blank -%}
      {%- liquid
        case block.settings.accent_color
          when 'blue'
            assign icon_bg = '#0076DE'
            assign text_fill = '#0076DE'
            assign is_grad = false
          when 'yellow'
            assign icon_bg = '#fdcd6a'
            assign text_fill = '#c98a10'
            assign is_grad = false
          when 'navy'
            assign icon_bg = '#1B2034'
            assign text_fill = '#1B2034'
            assign is_grad = false
          when 'green'
            assign icon_bg = '#10b981'
            assign text_fill = '#10b981'
            assign is_grad = false
          when 'orange'
            assign icon_bg = '#f97316'
            assign text_fill = '#f97316'
            assign is_grad = false
          when 'grad_magenta_blue'
            assign icon_bg = 'linear-gradient(135deg, #d946ef, #0076DE)'
            assign text_fill = 'linear-gradient(135deg, #b81fd4, #0076DE)'
            assign is_grad = true
          when 'grad_blue_navy'
            assign icon_bg = 'linear-gradient(135deg, #0076DE, #1B2034)'
            assign text_fill = 'linear-gradient(135deg, #0076DE, #1B2034)'
            assign is_grad = true
          when 'grad_green_blue'
            assign icon_bg = 'linear-gradient(135deg, #10b981, #0076DE)'
            assign text_fill = 'linear-gradient(135deg, #0c875f, #0076DE)'
            assign is_grad = true
          when 'grad_yellow_orange'
            assign icon_bg = 'linear-gradient(135deg, #fdcd6a, #f97316)'
            assign text_fill = 'linear-gradient(135deg, #c98a10, #d9620e)'
            assign is_grad = true
          when 'grad_magenta_orange'
            assign icon_bg = 'linear-gradient(135deg, #d946ef, #f97316)'
            assign text_fill = 'linear-gradient(135deg, #b81fd4, #d9620e)'
            assign is_grad = true
          when 'grad_navy_blue'
            assign icon_bg = 'linear-gradient(135deg, #1B2034, #0076DE)'
            assign text_fill = 'linear-gradient(135deg, #1B2034, #0076DE)'
            assign is_grad = true
          else
            assign icon_bg = '#d946ef'
            assign text_fill = '#d946ef'
            assign is_grad = false
        endcase
        assign modal_id = 'qmodal-' | append: section.id | append: '-' | append: block.id
      -%}
      {%- if is_grad -%}
        {%- capture mt_style -%}color:#1B2034;background:{{ text_fill }};-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;{%- endcapture -%}
      {%- else -%}
        {%- capture mt_style -%}color:{{ text_fill }};{%- endcapture -%}
      {%- endif -%}
      <div class="hub-questions__modal" id="{{ modal_id }}" hidden>
        <div class="hub-questions__modal-backdrop" data-modal-close></div>
        <div class="hub-questions__dialog"
             role="dialog"
             aria-modal="true"
             aria-labelledby="{{ modal_id }}-title">
          <button type="button" class="hub-questions__modal-close" data-modal-close aria-label="Close">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
          <div class="hub-questions__modal-head">
            <span class="hub-questions__modal-icon" style="background:{{ icon_bg }};">
              {%- render 'lucide-icon', icon: block.settings.icon -%}
            </span>
            <h2 class="hub-questions__modal-title" id="{{ modal_id }}-title" style="{{ mt_style }}">{{ block.settings.question | escape }}</h2>
          </div>
          {%- if block.settings.answer != blank -%}
            <div class="hub-questions__modal-answer">{{ block.settings.answer | escape | newline_to_br }}</div>
          {%- endif -%}
          {%- if block.settings.cta_url != blank and block.settings.cta_label != blank -%}
            <a href="{{ block.settings.cta_url }}" class="hub-questions__modal-cta">
              {{ block.settings.cta_label | escape }}
              <span aria-hidden="true">→</span>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}
</section>

<style>
  /* Head */
  .hub-questions__head {
    margin-bottom: 1.75rem;
  }
  .hub-questions__head-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--zone-accent, #d946ef);
    margin: 0 0 0.5rem;
  }
  .hub-questions__head-title {
    font-size: clamp(1.375rem, 2.2vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--hub-text);
    margin: 0;
    line-height: 1.2;
  }

  /* Grid: 3 / 2 / 1 columns */
  .hub-questions__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* Card (a reset <button>) */
  .hub-questions__card {
    appearance: none;
    -webkit-appearance: none;
    text-align: left;
    font-family: inherit;
    width: 100%;
    margin: 0;
    cursor: pointer;
    background: var(--hub-card-bg);
    border: 1px solid rgba(28, 33, 53, 0.06);
    border-radius: var(--hub-card-radius);
    box-shadow: var(--hub-card-shadow-rest);
    padding: 1.25rem 1.5rem;
    min-height: 110px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    transition: transform 0.25s var(--hub-ease), box-shadow 0.25s ease;
  }
  .hub-questions__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--hub-card-shadow-hover);
  }
  .hub-questions__card:focus-visible {
    outline: 2px solid var(--zone-accent, #d946ef);
    outline-offset: 2px;
  }

  .hub-questions__eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0 0 0.75rem;
  }
  .hub-questions__main {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    width: 100%;
  }
  .hub-questions__icon-wrap {
    width: 52px;
    height: 52px;
    flex: 0 0 auto;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    margin: 0;
  }
  .hub-questions__icon-wrap .lucide-icon {
    width: 56%;
    height: 56%;
  }
  .hub-questions__question {
    flex: 1;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    text-align: left;
    letter-spacing: -0.01em;
  }

  /* Modal */
  .hub-questions__modal[hidden] { display: none; }
  .hub-questions__modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .hub-questions__modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 18, 30, 0.55);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .hub-questions__dialog {
    position: relative;
    background: #ffffff;
    border-radius: 20px;
    max-width: 640px;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    padding: 2.5rem;
    box-shadow: 0 24px 60px rgba(15, 18, 30, 0.25);
    opacity: 0;
    transform: translateY(12px) scale(0.98);
    transition: opacity 0.25s ease, transform 0.25s var(--hub-ease);
  }
  .hub-questions__modal.is-open .hub-questions__modal-backdrop { opacity: 1; }
  .hub-questions__modal.is-open .hub-questions__dialog {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .hub-questions__modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 36px;
    height: 36px;
    border: 0;
    border-radius: 999px;
    background: rgba(28, 33, 53, 0.06);
    color: var(--hub-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }
  .hub-questions__modal-close:hover { background: rgba(28, 33, 53, 0.12); }
  .hub-questions__modal-close svg { width: 18px; height: 18px; }
  .hub-questions__modal-head {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin: 0 2.5rem 1.25rem 0;
  }
  .hub-questions__modal-icon {
    width: 52px;
    height: 52px;
    flex: 0 0 auto;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
  }
  .hub-questions__modal-icon .lucide-icon {
    width: 56%;
    height: 56%;
  }
  .hub-questions__modal-title {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.25;
  }
  .hub-questions__modal-answer {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--hub-text);
  }
  .hub-questions__modal-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--zone-accent, #d946ef);
    text-decoration: none;
  }
  .hub-questions__modal-cta:hover { gap: 0.65rem; }

  @media (max-width: 990px) {
    .hub-questions__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .hub-questions__grid { grid-template-columns: 1fr; }
    .hub-questions__card { padding: 1.5rem; border-radius: var(--hub-card-radius-mobile); }
    .hub-questions__dialog { padding: 1.75rem; }
    .hub-questions__modal-title { font-size: 1.25rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hub-questions__card,
    .hub-questions__modal-backdrop,
    .hub-questions__dialog { transition: none; }
  }
</style>

<script>
  (function() {
    var section = document.getElementById('{{ section_id }}');
    if (!section) return;

    var triggers = section.querySelectorAll('[data-modal-trigger]');
    var lastFocused = null;
    var openModal = null;

    function lockScroll(lock) {
      document.documentElement.style.overflow = lock ? 'hidden' : '';
      document.body.style.overflow = lock ? 'hidden' : '';
    }

    function close() {
      if (!openModal) return;
      var modal = openModal;
      modal.classList.remove('is-open');
      window.setTimeout(function() { modal.hidden = true; }, 250);
      lockScroll(false);
      openModal = null;
      if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    function open(modal, trigger) {
      lastFocused = trigger;
      modal.hidden = false;
      // force reflow so the transition runs from the hidden state
      void modal.offsetWidth;
      modal.classList.add('is-open');
      lockScroll(true);
      openModal = modal;
      var closeBtn = modal.querySelector('.hub-questions__modal-close');
      if (closeBtn) closeBtn.focus();
    }

    triggers.forEach(function(trigger) {
      trigger.addEventListener('click', function() {
        var modal = document.getElementById(trigger.getAttribute('data-modal-trigger'));
        if (modal) open(modal, trigger);
      });
    });

    section.querySelectorAll('[data-modal-close]').forEach(function(el) {
      el.addEventListener('click', close);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && openModal) close();
    });

    var revealEl = section.querySelector('.hub-questions--reveal');
    if (revealEl) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            revealEl.classList.add('is-revealed');
            observer.unobserve(revealEl);
          }
        });
      }, { threshold: 0.1 });
      observer.observe(revealEl);
    }
  })();
</script>

{% schema %}
{
  "name": "Hub: Quick Questions",
  "tag": "section",
  "class": "hub-quick-questions-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section heading", "default": "Quick questions" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow tag", "info": "Small label above the heading and on each card.", "default": "Q&A" },
    { "type": "checkbox", "id": "reveal_animation", "label": "Slide-up animation on scroll", "default": true },
    { "type": "color", "id": "bg_colour", "label": "Section background", "default": "#f5f5f7" },
    { "type": "color", "id": "accent_colour", "label": "Zone accent (head eyebrow, focus ring, modal CTA)", "default": "#d946ef" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question card",
      "limit": 12,
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "info": "Required. Shown on the card and as the modal title.", "default": "Kit or individual components?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "info": "Shown in the modal. Line breaks are preserved." },
        { "type": "select", "id": "icon", "label": "Icon", "default": "help", "options": [
          { "value": "lightbulb", "label": "Lightbulb" },
          { "value": "wrench", "label": "Wrench" },
          { "value": "cog", "label": "Cog" },
          { "value": "cable", "label": "Cable / wire" },
          { "value": "plug", "label": "Plug" },
          { "value": "book", "label": "Book" },
          { "value": "help", "label": "Help" },
          { "value": "clock", "label": "Clock" },
          { "value": "truck", "label": "Truck" },
          { "value": "shield", "label": "Shield" },
          { "value": "target", "label": "Target" },
          { "value": "info", "label": "Info" }
        ] },
        { "type": "select", "id": "accent_color", "label": "Accent colour", "default": "magenta", "options": [
          { "value": "magenta", "label": "Magenta" },
          { "value": "blue", "label": "Blue" },
          { "value": "yellow", "label": "Yellow" },
          { "value": "navy", "label": "Navy" },
          { "value": "green", "label": "Green" },
          { "value": "orange", "label": "Orange" },
          { "value": "grad_magenta_blue", "label": "Gradient — Magenta → Blue" },
          { "value": "grad_blue_navy", "label": "Gradient — Blue → Navy" },
          { "value": "grad_green_blue", "label": "Gradient — Green → Blue" },
          { "value": "grad_yellow_orange", "label": "Gradient — Yellow → Orange" },
          { "value": "grad_magenta_orange", "label": "Gradient — Magenta → Orange" },
          { "value": "grad_navy_blue", "label": "Gradient — Navy → Blue" }
        ] },
        { "type": "text", "id": "cta_label", "label": "CTA label (optional)" },
        { "type": "url", "id": "cta_url", "label": "CTA URL (optional)" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Hub: Quick Questions",
      "blocks": [
        { "type": "question" },
        { "type": "question" },
        { "type": "question" },
        { "type": "question" },
        { "type": "question" },
        { "type": "question" }
      ]
    }
  ]
}
{% endschema %}
