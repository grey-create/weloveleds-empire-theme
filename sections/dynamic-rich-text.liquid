<script
  type="application/json"
  data-section-id="{{ section.id }}"
  data-section-type="dynamic-rich-text"
></script>

<script type="application/pxs-animation-mapping+json">
  {
    "blocks": [".rich-text-block"],
    "elements": []
  }
</script>

<style>
/* Compact styling - this section is homepage only */
.rich-text--section {
  margin-bottom: 0 !important;
}
.rich-text--container {
  padding-top: 20px !important;
  padding-bottom: 20px !important;
  margin-top: 0 !important;
  margin-bottom: 0 !important;
}
.rich-text-block {
  margin-bottom: 0 !important;
  padding: 0 !important;
}
.rich-text-heading {
  font-size: 1.75rem !important;
  margin: 0 !important;
}
.rich-text-content {
  font-size: 0.9rem !important;
  margin-top: 0.5rem !important;
  opacity: 0.85 !important;
}
@media (max-width: 767px) {
  .rich-text--container {
    padding-top: 15px !important;
    padding-bottom: 15px !important;
  }
  .rich-text-heading {
    font-size: 1.4rem !important;
  }
}
</style>

<section
  class="
    rich-text--container
    rich-text-{{ section.settings.width }}
    {% if section.settings.title == 'LEDs For Signs, Displays & Décor' %}rich-text-full-width{% endif %}
  "
  {% if section.settings.title == 'LEDs For Signs, Displays & Décor' %}
  style="background-image: url('https://cdn.shopify.com/s/files/1/1070/8974/files/Wavy-Lines-2400x500.jpg?v=1762520101'); background-size: cover; background-position: center; background-color: #1b2034;"
{% endif %}
>
    <div
      class="
        rich-text-block
        rich-text-alignment-{{ section.settings.text_alignment }}
      "
      {{ section.shopify_attributes }}
    >
        {% if section.settings.title != blank %}
          <h2
            class="
              rich-text-heading
              rich-text-heading-{{ section.settings.heading_size }}
            "
          >
            {{ section.settings.title | escape }}
          </h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="rich-text-content rte" data-rte>
            {{ section.settings.text | raw }}

          </div>
        {% endif %}
    </div>
</section>

{% schema %}
{
  "name": "t:sections.rich_text.name",
  "class": "rich-text--section",
  "settings": [
    {
      "id": "width",
      "type": "select",
      "label": "t:sections.rich_text.width.label",
      "options": [
        {
          "value": "regular",
          "label": "t:sections.rich_text.width.option_1"
        },
        {
          "value": "wide",
          "label": "t:sections.rich_text.width.option_2"
        },
        {
          "value": "full-width",
          "label": "t:sections.rich_text.width.option_3"
        }
      ],
      "default": "regular"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.rich_text.title.label",
      "default": "Rich text"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.rich_text.text.label",
      "default": "<p>Use this section to welcome customers to your store, say a bit about your brand, or share news and seasonal promotions.</p>"
    },
    {
      "id": "heading_size",
      "type": "select",
      "label": "t:sections.rich_text.heading_size.label",
      "options": [
        {
          "value": "small",
          "label": "t:sections.rich_text.heading_size.option_1"
        },
        {
          "value": "medium",
          "label": "t:sections.rich_text.heading_size.option_2"
        },
        {
          "value": "large",
          "label": "t:sections.rich_text.heading_size.option_3"
        }
      ],
      "default": "medium"
    },
    {
      "id": "text_alignment",
      "type": "select",
      "label": "t:sections.rich_text.text_alignment.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.rich_text.text_alignment.option_1"
        },
        {
          "value": "center",
          "label": "t:sections.rich_text.text_alignment.option_2"
        },
        {
          "value": "right",
          "label": "t:sections.rich_text.text_alignment.option_3"
        }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "t:sections.rich_text.presets.rich_text.name",
      "category": "t:sections.rich_text.presets.rich_text.category",
      "settings": {}
    }
  ],
  "disabled_on": {
    "groups": ["*"]
  }
}
{% endschema %}