{%- liquid
  assign bg_colour = section.settings.bg_colour
  assign accent_colour = section.settings.accent_colour
  assign reveal = section.settings.reveal_on_scroll
  assign card_theme = section.settings.card_theme | default: 'light'
-%}

{{ 'hub-shared.css' | asset_url | stylesheet_tag }}

{%- if section.blocks.size > 0 -%}
<section class="hub-route hub-route--theme-{{ card_theme }}"
         data-section-id="{{ section.id }}"
         style="background: {{ bg_colour }}; --zone-accent: {{ accent_colour }};">
  <div class="hub-route__container{% if reveal %} hub-route--reveal{% endif %}">

    {%- render 'hub-carousel-controls', prefix: 'hub-route', wrap_label: 'Scroll category cards' -%}

    <div class="hub-route__scroll" data-route-scroll>
      <ul class="hub-route__strip">
        {%- for block in section.blocks -%}
          {%- if block.type == 'card' -%}
            {%- if block.settings.title == blank and block.settings.link == blank -%}
              {%- continue -%}
            {%- endif -%}

            {%- liquid
              assign card_t = card_theme
              assign theme_override = block.settings.card_theme_override
              if theme_override != blank and theme_override != 'inherit'
                assign card_t = theme_override
              endif

              if card_t == 'dark'
                assign card_style = 'background:#1B2034;color:#ffffff;'
                assign placeholder_style = 'background:linear-gradient(to top, rgba(217, 70, 239, 0.28) 0%, #1B2034 60%);'
              else
                assign card_style = 'background:#ffffff;color:var(--hub-text);'
                assign placeholder_style = 'background:linear-gradient(to top, rgba(217, 70, 239, 0.18) 0%, #ffffff 60%);'
              endif
            -%}

            <li class="hub-route__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="hub-route__card" style="{{ card_style }}">
              {%- else -%}
              <div class="hub-route__card" style="{{ card_style }}">
              {%- endif -%}
                <div class="hub-route__media">
                  {%- if block.settings.image -%}
                    <img src="{{ block.settings.image | image_url: width: 600 }}"
                         alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                         loading="lazy"
                         width="600" height="600">
                  {%- else -%}
                    <div class="hub-route__media-placeholder" aria-hidden="true" style="{{ placeholder_style }}"></div>
                  {%- endif -%}
                </div>
                <div class="hub-route__overlay">
                  {%- if block.settings.eyebrow != blank -%}
                    <span class="hub-route__eyebrow">{{ block.settings.eyebrow | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.title != blank -%}
                    <h3 class="hub-route__title">{{ block.settings.title | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="hub-route__description">{{ block.settings.description | escape | newline_to_br }}</p>
                  {%- endif -%}
                </div>
              {%- if block.settings.link != blank -%}
              </a>
              {%- else -%}
              </div>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

  </div>
</section>

<style>
.hub-route__container {
  position: relative;
  padding-left: var(--hub-rail-pad);
  padding-right: var(--hub-rail-pad);
}

/* Nav arrows in a row above the cards, right-aligned */
.hub-route__nav-wrap {
  display: flex;
  justify-content: flex-end;
  gap: 0.5rem;
  margin-bottom: 0.5rem;
}
/* Hide arrows when content fits without overflow (toggled by JS) */
.hub-route--no-overflow .hub-route__nav-wrap { display: none; }

/* Scroll strip bleed — overflow + snap mechanic in hub-shared.css */
.hub-route__scroll {
  /* Padding for shadow space all around - top covers hover lift + shadow above */
  padding-top: 1rem;
  padding-bottom: 2rem;
  /* Full-viewport breakout so cards extend off the right edge */
  width: 100vw;
  position: relative;
  left: 50%;
  margin-left: -50vw;
  margin-right: 0;
  /* Align first card with rail. Adds 1.5rem to compensate for the chassis section
     padding that the container is offset by — without this, the strip's breakout
     would land first card 24px left of every other hub section's content edge. */
  padding-left: calc(var(--hub-rail-pad) + 1.5rem);
  /* scroll-padding-left moves the snap-target origin to match padding, so mandatory snap
     no longer auto-scrolls to align first card with the box edge */
  scroll-padding-left: calc(var(--hub-rail-pad) + 1.5rem);
  padding-right: 0;
}

/* Item width: Apple-sized cards. 240px floor → 460px ceiling.
   At 4K cards reach ~449px (close to ceiling). Below 4K cards are smaller. With this
   sizing 6 cards may NOT overflow at very wide viewports — the JS adds
   .hub-route--no-overflow to the section in that case, which hides the nav arrows. */
.hub-route__item {
  flex-basis: clamp(240px, calc(180px + 7vw), 460px);
}

/* Magazine-style card: full-bleed image + overlaid title, 4:5 aspect */
.hub-route__card {
  position: relative;
  display: block;
  width: 100%;
  aspect-ratio: 4 / 5;
  border-radius: var(--hub-card-radius);
  overflow: hidden;
  text-decoration: none;
  box-shadow: var(--hub-card-shadow-rest);
  transition: transform 0.25s var(--hub-ease), box-shadow 0.25s ease;
}
.hub-route__card:hover {
  transform: translateY(-4px);
  box-shadow: var(--hub-card-shadow-hover);
}

/* Theme variants — surface colour + foreground text */
.hub-route--theme-light .hub-route__card {
  background: #ffffff;
  color: var(--hub-text);
}
.hub-route--theme-dark .hub-route__card {
  background: #1B2034;
  color: #ffffff;
}

/* Media: fills the entire card behind the text */
.hub-route__media {
  position: absolute;
  inset: 0;
  overflow: hidden;
}
.hub-route__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: bottom;
  transition: transform 0.4s var(--hub-ease);
}
.hub-route__card:hover .hub-route__media img {
  transform: scale(1.03);
}

/* Placeholder gradient — subtle magenta wash, themed */
.hub-route__media-placeholder {
  position: absolute;
  inset: 0;
}
.hub-route--theme-light .hub-route__media-placeholder {
  background: linear-gradient(to top, rgba(217, 70, 239, 0.18) 0%, #ffffff 60%);
}
.hub-route--theme-dark .hub-route__media-placeholder {
  background: linear-gradient(to top, rgba(217, 70, 239, 0.28) 0%, #1B2034 60%);
}

/* Overlay: title block top-left, sits above media */
.hub-route__overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 1.5rem;
  z-index: 1;
}
.hub-route__eyebrow {
  display: block;
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin: 0 0 0.5rem;
}
.hub-route__title {
  font-size: 1.375rem;
  font-weight: 600;
  margin: 0;
  letter-spacing: -0.022em;
  line-height: 1.15;
}
.hub-route__description {
  font-size: 0.9375rem;
  font-weight: 600;
  letter-spacing: -0.018em;
  line-height: 1.3;
  margin: 0.5rem 0 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

@media (max-width: 990px) {
  .hub-route__overlay { padding: 1.25rem; }
  .hub-route__title { font-size: 1.25rem; }
}
@media (max-width: 600px) {
  .hub-route__card { border-radius: var(--hub-card-radius-mobile); }
  .hub-route__overlay { padding: 1rem 1rem 1.25rem; }
  .hub-route__title { font-size: 1.125rem; }
  .hub-route__description { font-size: 0.8125rem; }
  .hub-route__eyebrow { font-size: 0.625rem; }
}
@media (prefers-reduced-motion: reduce) {
  .hub-route__media img { transition: none; }
}
</style>

<script>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var sections = document.querySelectorAll('.hub-route');
    sections.forEach(function(section) {
      if (section.dataset.processed === 'true') return;
      section.dataset.processed = 'true';

      var scroll = section.querySelector('[data-route-scroll]');
      var prev = section.querySelector('[data-direction="prev"]');
      var next = section.querySelector('[data-direction="next"]');
      if (!scroll || !prev || !next) return;

      function scrollByCard(direction) {
        var firstItem = scroll.querySelector('.hub-route__item');
        if (!firstItem) return;
        var styles = getComputedStyle(scroll.querySelector('.hub-route__strip'));
        var gap = parseFloat(styles.gap) || 20;
        var cardWidth = firstItem.getBoundingClientRect().width + gap;
        scroll.scrollBy({ left: cardWidth * direction, behavior: 'smooth' });
      }

      function updateButtons() {
        var maxScroll = scroll.scrollWidth - scroll.clientWidth - 1;
        prev.disabled = scroll.scrollLeft <= 0;
        next.disabled = scroll.scrollLeft >= maxScroll;
      }

      prev.addEventListener('click', function() { scrollByCard(-1); });
      next.addEventListener('click', function() { scrollByCard(1); });
      scroll.addEventListener('scroll', updateButtons, { passive: true });

      function checkOverflow() {
        if (!scroll) return;
        if (scroll.scrollWidth > scroll.clientWidth + 1) {
          section.classList.remove('hub-route--no-overflow');
        } else {
          section.classList.add('hub-route--no-overflow');
        }
      }

      var resizeTimer;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function() {
          checkOverflow();
          updateButtons();
        }, 150);
      });

      checkOverflow();
      updateButtons();
    });

    if (!('IntersectionObserver' in window)) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
    document.querySelectorAll('.hub-route--reveal').forEach(function(el) { observer.observe(el); });
  });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Hub Choose Your Route",
  "tag": "section",
  "class": "section-hub-route",
  "settings": [
    { "type": "paragraph", "content": "Legacy — no longer used. Cards are now driven by the editable Category card blocks below. The Menu handle and CTA label fields are retained only for backward compatibility and have no effect on the rendered output." },
    { "type": "text", "id": "menu_handle", "label": "Menu handle (legacy)", "default": "fairground-lights" },
    { "type": "text", "id": "cta_label", "label": "CTA label (legacy)", "default": "Shop Now" },
    { "type": "color", "id": "bg_colour", "label": "Background colour", "default": "#f5f5f7" },
    { "type": "color", "id": "accent_colour", "label": "Zone accent colour", "default": "#0076DE" },
    { "type": "select", "id": "card_theme", "label": "Card theme", "default": "light", "options": [
      { "value": "light", "label": "Light (white card, navy text)" },
      { "value": "dark", "label": "Dark (navy card, white text)" }
    ] },
    { "type": "checkbox", "id": "reveal_on_scroll", "label": "Fade in on scroll", "default": true }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Category card",
      "limit": 12,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "info": "Required. Card heading.", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link", "info": "Required. Destination collection or page." },
        { "type": "image_picker", "id": "image", "label": "Image", "info": "Optional. Falls back to a themed magenta placeholder gradient." },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "info": "Optional small uppercase label above the title." },
        { "type": "textarea", "id": "description", "label": "Description", "info": "Optional supporting copy (multi-line)." },
        { "type": "select", "id": "card_theme_override", "label": "Card theme override", "default": "inherit", "options": [
          { "value": "inherit", "label": "Inherit section theme" },
          { "value": "light", "label": "Light (white card, navy text)" },
          { "value": "dark", "label": "Dark (navy card, white text)" }
        ] }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Hub Choose Your Route",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
