    .sf-46, .sf-47, .sf-48, .sf-49, .sf-50 {
      display: none;
    }
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .snowflake {
      animation: none;
      display: none;
    }
  }
