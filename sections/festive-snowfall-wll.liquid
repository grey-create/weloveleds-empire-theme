  .sf-2 { --pos-x: 97%; --size: 9px; --duration: 11s; --delay: -8s; --opacity: 0.8; --start-y: -12%; --drift-1: -20px; --drift-2: 25px; --drift-3: -10px; --drift-4: 20px; }
