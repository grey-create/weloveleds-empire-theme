      "type": "checkbox",
      "id": "enable_snowfall",
      "label": "Enable Snowfall Effect",
      "default": true,
      "info": "Toggle the falling snow animation on/off"
    },
    {
      "type": "paragraph",
      "content": "Pure CSS snowfall effect - no impact on site speed. Automatically reduces on mobile and respects user motion preferences."
    }
  ],
  "presets": [
    {
      "name": "❄️ Festive Snowfall"
    }
  ]
}
{% endschema %}
