          {%- else -%}
            <div class="bento-tile__overlay" style="background: {{ section.settings.tile_2_overlay }}; mix-blend-mode: {{ section.settings.tile_2_blend_mode }};"></div>
          {%- endif -%}
        </div>
        <div class="bento-tile__content">
          <h2 class="bento-tile__title">
            {%- if section.settings.tile_2_title != blank -%}
              {{ section.settings.tile_2_title }}
            {%- else -%}
