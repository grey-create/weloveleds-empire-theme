{% schema %}
{
  "name": "Bento Grid - Core",
  "tag": "section",
  "class": "bento-grid-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width layout",
      "info": "Extends grid edge-to-edge like Apple",
      "default": true
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "info": "Prevents tiles becoming too large on ultra-wide screens",
      "min": 1400,
      "max": 2400,
      "step": 100,
      "default": 1800,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "background_colour",
      "label": "Background colour",
      "default": "#f5f5f7"
    },
    {
      "type": "range",
      "id": "gap_size",
      "label": "Gap between tiles",
      "min": 8,
      "max": 24,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Tile corner radius",
      "min": 8,
      "max": 32,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Tile 1: Hero (Large)"
    },
    {
      "type": "collection",
      "id": "tile_1_collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "tile_1_title",
      "label": "Custom title",
      "info": "Leave blank to use collection title"
    },
    {
      "type": "text",
      "id": "tile_1_tagline",
      "label": "Tagline",
      "default": "Professional LED strips with 5-year warranty"
    },
    {
      "type": "image_picker",
      "id": "tile_1_image",
      "label": "Background image"
    },
    {
      "type": "color_background",
      "id": "tile_1_overlay",
      "label": "Overlay gradient",
      "default": "linear-gradient(135deg, rgba(6, 78, 59, 0.95) 0%, rgba(0, 0, 0, 0.9) 100%)"
    },
    {
      "type": "select",
      "id": "tile_1_blend_mode",
      "label": "Blend mode",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "multiply", "label": "Multiply" },
        { "value": "overlay", "label": "Overlay" },
        { "value": "soft-light", "label": "Soft Light" },
        { "value": "hard-light", "label": "Hard Light" }
      ],
      "default": "normal"
    },
    {
      "type": "checkbox",
      "id": "tile_1_fade_to_transparent",
      "label": "Fade to transparent",
      "info": "Adds a fade from bottom to transparent, ignoring gradient",
      "default": false
    },
    {
      "type": "color",
      "id": "tile_1_fade_colour",
      "label": "Fade colour (if enabled above)",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "tile_1_fade_opacity",
      "label": "Fade opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 80,
      "unit": "%"
    },
