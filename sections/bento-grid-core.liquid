{{ 'bento-grid-core.css' | asset_url | stylesheet_tag }}

<div class="bento-grid-section {% if section.settings.full_width %}bento-grid-section--full-width{% endif %}" style="background-color: {{ section.settings.background_colour }};">
  <div class="bento-grid-container" style="--bento-max-width: {{ section.settings.max_width }}px;">
    <div class="bento-grid" style="gap: {{ section.settings.gap_size }}px; --bento-radius: {{ section.settings.border_radius }}px;">
      
      {%- comment -%} Tile 1: Hero (Large) {%- endcomment -%}
      <a href="{{ section.settings.tile_1_collection.url }}" class="bento-tile bento-tile--hero">
        <div class="bento-tile__background">
          {%- if section.settings.tile_1_image != blank -%}
            {{ section.settings.tile_1_image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'bento-tile__image' }}
          {%- endif -%}
          {%- if section.settings.tile_1_fade_to_transparent -%}
            {%- assign fade_opacity = section.settings.tile_1_fade_opacity | divided_by: 100.0 -%}
            <div class="bento-tile__overlay" style="background: linear-gradient(to top, {{ section.settings.tile_1_fade_colour | color_modify: 'alpha', fade_opacity }}, transparent); mix-blend-mode: {{ section.settings.tile_1_blend_mode }};"></div>
          {%- else -%}
            <div class="bento-tile__overlay" style="background: {{ section.settings.tile_1_overlay }}; mix-blend-mode: {{ section.settings.tile_1_blend_mode }};"></div>
          {%- endif -%}
        </div>
        <div class="bento-tile__content">
          <h2 class="bento-tile__title bento-tile__title--large">
            {%- if section.settings.tile_1_title != blank -%}
              {{ section.settings.tile_1_title }}
            {%- else -%}
              {{ section.settings.tile_1_collection.title }}
            {%- endif -%}
          </h2>
          {%- if section.settings.tile_1_tagline != blank -%}
            <p class="bento-tile__tagline">{{ section.settings.tile_1_tagline }}</p>
          {%- endif -%}
          <span class="bento-tile__cta">Shop now <span class="bento-tile__arrow">→</span></span>
        </div>
      </a>

      {%- comment -%} Tile 2: Tall {%- endcomment -%}
      <a href="{{ section.settings.tile_2_collection.url }}" class="bento-tile bento-tile--tall">
        <div class="bento-tile__background">
          {%- if section.settings.tile_2_image != blank -%}
            {{ section.settings.tile_2_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'bento-tile__image' }}
          {%- endif -%}
          {%- if section.settings.tile_2_fade_to_transparent -%}
            {%- assign fade_opacity = section.settings.tile_2_fade_opacity | divided_by: 100.0 -%}
