{%- liquid
  assign heading = section.settings.heading
  assign heading_muted = section.settings.heading_muted
-%}

{% if section.blocks.size > 0 %}
<section class="wll-section collection-cross-sell" data-section-id="{{ section.id }}">
  <div class="wll-section__inner">
    {% if heading != blank %}
      <h2 class="wll-zone__heading">{{ heading | escape }}{% if heading_muted != blank %} <span class="muted">{{ heading_muted | escape }}</span>{% endif %}</h2>
    {% endif %}
    <div class="collection-cross-sell__pills">
      {% for block in section.blocks %}
        {% if block.type == 'link' and block.settings.link_label != blank %}
          <a href="{{ block.settings.link_url | default: '#' }}" class="wll-linkpill" {{ block.shopify_attributes }}>{{ block.settings.link_label | escape }}</a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
.collection-cross-sell__pills { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.25rem; }
</style>
{% endif %}

{% schema %}
{
  "name": "Collection Cross-sell",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading (bold part)", "default": "Complete your setup." },
    { "type": "text", "id": "heading_muted", "label": "Heading (muted continuation)", "default": "Everything else you might need." }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link pill",
      "settings": [
        { "type": "text", "id": "link_label", "label": "Label" },
        { "type": "url", "id": "link_url", "label": "URL" }
      ]
    }
  ],
  "presets": [ { "name": "Collection Cross-sell" } ]
}
{% endschema %}
