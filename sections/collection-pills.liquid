{% comment %}
  Collection Pills Bar for WeLoveLEDs
  Compact horizontal navigation showing all collections
{% endcomment %}

{{ 'collection-pills.css' | asset_url | stylesheet_tag }}

<div class="collection-pills" style="background-color: {{ section.settings.background_colour }};">
  <div class="collection-pills__container">
    {% if section.settings.heading != blank %}
      <p class="collection-pills__heading">{{ section.settings.heading }}</p>
    {% endif %}
    
    <div class="collection-pills__list">
      {% for block in section.blocks %}
        {% if block.settings.collection != blank %}
          <a href="{{ block.settings.collection.url }}" class="collection-pills__pill" {{ block.shopify_attributes }}>
            {% if section.settings.show_images and block.settings.collection.image != blank %}
              <span class="collection-pills__pill-image">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 80 | image_tag: loading: 'lazy' }}
                {% else %}
                  {{ block.settings.collection.image | image_url: width: 80 | image_tag: loading: 'lazy' }}
                {% endif %}
              </span>
            {% endif %}
            <span class="collection-pills__pill-text">
              {% if block.settings.title != blank %}
                {{ block.settings.title }}
              {% else %}
                {{ block.settings.collection.title }}
              {% endif %}
            </span>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Pills",
  "tag": "section",
  "class": "collection-pills-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "color",
      "id": "background_colour",
      "label": "Background colour",
      "default": "#f5f5f7"
    },
    {
      "type": "checkbox",
      "id": "show_images",
      "label": "Show collection images",
      "default": false,
      "info": "Display small circular images in pills"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override title",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override image",
          "info": "Only used if 'Show collection images' is enabled"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Pills",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
