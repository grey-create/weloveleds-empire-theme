{% doc %}
  @prompt
    Gallery

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gallery-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding }}px;
  }

  .ai-gallery-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-gallery-item-{{ ai_gen_id }}:hover {
    transform: scale({{ block.settings.hover_scale }});
  }

  .ai-gallery-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;display: block;
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 250px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.5;
  }

  .ai-gallery-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-gallery-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }}) 100%
    );opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: flex-end;
    padding: 20px;
  }

  .ai-gallery-item-{{ ai_gen_id }}:hover .ai-gallery-overlay-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-gallery-caption-{{ ai_gen_id }} {
    color: white;
    font-size: 16px;
    font-weight: 500;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }

  {% if block.settings.aspect_ratio == 'square' %}
    .ai-gallery-item-{{ ai_gen_id }} {
      aspect-ratio: 1;
    }
  {% elsif block.settings.aspect_ratio == 'portrait' %}
    .ai-gallery-item-{{ ai_gen_id }} {
      aspect-ratio: 3/4;
    }
  {% elsif block.settings.aspect_ratio == 'landscape' %}
    .ai-gallery-item-{{ ai_gen_id }} {
      aspect-ratio: 4/3;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-gallery-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);gap: {{ block.settings.gap | times: 0.7 }}px;
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }
  }
{% endstyle %}<div class="ai-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% for i in (1..9) %}
    {% assign image_key = 'image_' | append: i %}
    {% assign caption_key = 'caption_' | append: i %}
    {% assign image = block.settings[image_key] %}
    {% assign caption = block.settings[caption_key] %}

    {% if image != blank %}
      <div class="ai-gallery-item-{{ ai_gen_id }}">
        <img
          src="{{ image | image_url: width: 800 }}"
          alt="{{ image.alt | escape }}"
          class="ai-gallery-image-{{ ai_gen_id }}"loading="lazy"
          width="{{ image.width }}"
          height="{{ image.height }}"
        >
        {% if caption != blank %}
          <div class="ai-gallery-overlay-{{ ai_gen_id }}">
            <div class="ai-gallery-caption-{{ ai_gen_id }}">{{ caption }}</div>
          </div>
        {% endif %}
      </div>
    {% elsif forloop.index <= 3 %}
      <div class="ai-gallery-item-{{ ai_gen_id }}">
        <div class="ai-gallery-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          {% if forloop.index == 1 %}
            <div class="ai-gallery-empty-state-{{ ai_gen_id }}">
              Add images to create your gallery
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>

